                fill="#FFC506"></path>
            </svg>
          </div>
          <span>Follow-up Tracking (Upcoming &amp; Missed)</span>
        </li>

        <li>
          <div class="event-app__check">
            <svg
              viewBox="0 0 24 24"
              fill="#FFC506"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M12 14C13.66 14 15 12.66 15 11V5C15 3.34 13.66 2 12 2C10.34 2 9 3.34 9 5V11C9 12.66 10.34 14 12 14ZM17 11C17 13.76 14.76 16 12 16C9.24 16 7 13.76 7 11H5C5 14.53 7.61 17.43 11 17.92V21H13V21V17.92C16.39 17.43 19 14.53 19 11H17Z"
              ></path>
            </svg>
          </div>
          <span>Voice Notes for Follow-ups</span>
        </li>
        <li>
          <div class="event-app__check">
            <svg
              width="57"
              height="60"
              viewBox="0 0 57 60"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
