    </div>

    <div
      class="event-app__visual"
      data-aos="fade-left"
      data-aos-duration="1200"
      data-aos-delay="400"
    >
      <img
        src="/images/event-app/event-app-final-image.webp"
        alt="Event App Interface"
        class="event-app__image"
      />
    </div>
  </div>
</section>

<style>
  .section--event-app {
    min-height: unset;
    background: url("/images/event-app/event-app-bg.webp") center center/cover
      no-repeat;
    background-color: #121212;
    color: #ffffff;
    padding: 5rem clamp(1rem, 5vw, 4rem);
    overflow: hidden;
  }

  .event-app__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(2rem, 5vw, 4rem);
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
  }

  .event-app__content {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
  }

  .event-app__title {
    font-size: clamp(2rem, 3vw, 2.6rem);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    line-height: 1.1;
    white-space: nowrap;
  }

  .event-app__divider {
    width: 100px;
    height: 4px;
    background: #22d3ee;
    border: none;
    margin-bottom: 2rem;
    border-radius: 2px;
  }

  .event-app__subtitle {
    font-size: clamp(1.2rem, 2.2vw, 1.8rem);
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 1.5rem;
    white-space: nowrap;
  }

  .event-app__subtitle .highlight {
    font-weight: 800;
  }

  .event-app__desc {
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    font-weight: 400;
  }

  .event-app__features {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .event-app__features li {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .event-app__check {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .event-app__check svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .event-app__visual {
    flex: 0 1 55%;
    display: flex;
    justify-content: flex-end;
  }

  .event-app__image {
    max-width: 115%;
    width: 115%;
    height: auto;
    object-fit: contain;
    transform: translateX(5%);
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.5));
  }

  .app-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #22d3ee;
    color: #0b0b0c;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 12px 26px;
    border-radius: 50px;
    text-decoration: none;
    margin-top: 1.5rem;
    width: max-content;
    position: relative;
    z-index: 1;
    overflow: hidden;
    transition:
      transform 0.3s cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 0.3s cubic-bezier(0.25, 1, 0.5, 1),
      background 0.3s ease;
    animation: heartbeat-pulse 2.5s infinite;
  }

  .app-cta-btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.6),
      transparent
    );
    transform: skewX(-20deg);
    transition: left 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    z-index: -1;
  }

  @keyframes heartbeat-pulse {
    0% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(34, 211, 238, 0.7);
    }
    15% {
      transform: scale(1.05);
      box-shadow: 0 0 0 10px rgba(34, 211, 238, 0.3);
    }
    30% {
      transform: scale(1);
      box-shadow: 0 0 0 20px rgba(34, 211, 238, 0);
    }
    100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(34, 211, 238, 0);
    }
  }

  .app-cta-btn:hover {
    animation: none;
    background: #0ea5e9;
    transform: translateY(-4px) scale(1.04);
    box-shadow: 0 12px 25px rgba(34, 211, 238, 0.4);
  }

  .app-cta-btn:hover::before {
    left: 200%;
  }

  .app-cta-btn span,
  .app-cta-btn svg {
    position: relative;
    z-index: 2;
  }

  .app-cta-btn svg {
    transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }

  .app-cta-btn:hover svg {
    transform: translateX(8px);
  }

  @media screen and (max-width: 991px) {
    .event-app__check {
      width: 32px;
      height: 32px;
    }

    .event-app__container {
      flex-direction: column;
      text-align: center;
      gap: 3rem;
    }

    .event-app__title,
    .event-app__subtitle,
    .event-app__desc {
      text-align: center;
    }

    .event-app__divider {
      margin: 1.5rem auto;
    }

    .event-app__features {
      width: fit-content;
      max-width: min(92%, 520px);
      margin-left: auto;
      margin-right: auto;
      align-items: flex-start;
    }

    .event-app__features li {
      text-align: left;
      justify-content: flex-start;
    }

    .event-app__visual {
      justify-content: center;
    }

    .event-app__image {
      transform: none;
      max-width: 100%;
      width: 100%;
    }
  }

  @media screen and (min-width: 992px) {
    .section--event-app {
      height: 100vh;
      display: flex;
      align-items: center;
      padding-top: 0;
      padding-bottom: 0;
    }
  }
</style>
