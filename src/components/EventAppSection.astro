---

---

<section id="event-app" class="section section--event-app">
  <div class="event-app__container">
    <div class="event-app__content">
      <h2 class="event-app__title" data-aos="fade-down" data-aos-duration="800">
        <span class="highlight">EVENT</span> APP
      </h2>
      <hr class="event-app__divider" data-aos="zoom-in" data-aos-delay="100" />
      <h3
        class="event-app__subtitle"
        data-aos="fade-right"
        data-aos-delay="200"
        data-aos-duration="1000"
      >
        Transform <span class="highlight">Events</span> Into<br />Interactive <span
          class="highlight">Digital Experiences</span>
      </h3>
      <p
        class="event-app__desc"
        data-aos="fade-right"
        data-aos-delay="300"
        data-aos-duration="1000"
      >
        Our smart customer management platform helps you manage leads, track
        follow-ups,<br />
        and streamline customer relationships with real-time insights.
      </p>

      <ul class="event-app__features">
        <li>
          <div class="event-app__check">
            <svg
              viewBox="0 0 24 24"
              fill="#FFC506"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M15 14C17.67 14 23 15.33 23 18V20H7V18C7 15.33 12.33 14 15 14ZM15 12C12.79 12 11 10.21 11 8C11 5.79 12.79 4 15 4C17.21 4 19 5.79 19 8C19 10.21 17.21 12 15 12ZM5 9V6H3V9H0V11H3V14H5V11H8V9H5Z"
              ></path>
            </svg>
          </div>
          <span>Customer Registration &amp; Management</span>
        </li>
        <li>
          <div class="event-app__check">
            <svg
              viewBox="0 0 24 24"
              fill="#FFC506"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M4 9V6C4 4.895 4.895 4 6 4H9V6H6V9H4Z"></path>
              <path d="M20 9V6C20 4.895 19.105 4 18 4H15V6H18V9H20Z"></path>
              <path d="M4 15V18C4 19.105 4.895 20 6 20H9V18H6V15H4Z"></path>
              <path d="M20 15V18C20 19.105 19.105 20 18 20H15V18H18V15H20Z"
              ></path>
              <rect x="8" y="8" width="8" height="2" rx="1"></rect>
              <rect x="7" y="11" width="10" height="2" rx="1"></rect>
              <rect x="8" y="14" width="8" height="2" rx="1"></rect>
            </svg>
          </div>
          <span>Business Card Scanner</span>
        </li>
        <li>
          <div class="event-app__check">
            <svg
              width="57"
              height="60"
              viewBox="0 0 57 60"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
