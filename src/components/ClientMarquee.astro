---
// src/components/ClientMarquee.astro
---
<section class="client-con">
  <div class="section-title1" style="text-align: center; margin-bottom: 2rem;">
    <h2 style="font-size: 2.5rem; font-weight: 800; color: #040e1b;">Our Clients</h2>
  </div>

  <div class="ClientSwiper swiper">
    <div class="swiper-wrapper">
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client1.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client3.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client4.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client5.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client6.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client7.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/Client8.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client9.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client10.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client11.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client12.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client13.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client14.png" loading="lazy" alt="Client"></div>
      <div class="slide1 swiper-slide"><img src="/images/home/clients/client15.png" loading="lazy" alt="Client"></div>
    </div>
  </div>
</section>

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />

<style>
.client-con {
  width: 100%;
  height: auto;
  padding: 50px 0;
  background: #f1f5f9;
}

.clientsec {
  margin: 50px 100px;
}

.slide img {
  width: 100px;
 
}

.slide1 {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 150px;
}

.slide1 img {
  width: auto;
  max-width: 80%;
  filter: grayscale(100%);
  transition: all 0.3s ease;
  object-fit: contain;
  max-height: 100px;
}

:global(.ClientSwiper .slide img:hover),
:global(.ClientSwiper .slide1 img:hover) {
  filter: grayscale(0%) !important;
}

.ClientSwiper {
  width: 90%;
  margin: 0 auto;
  overflow: hidden; /* Needed for Swiper */
}

:global(.ClientSwiper .swiper-slide-active img) {
  filter: grayscale(0%) !important;
}



@media screen and (max-width:1020px) {
  .slide img {
    width: 100px;
    padding: 10px;
  }
  .clientsec {
    width: 100%;
    overflow: hidden;
    margin: 50px;
  }
}

@media screen and (max-width:400px) {
  .clientsec {
    width: 100%;
    overflow: hidden;
    margin: 50px 0;
  }
}
</style>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js" is:inline></script>
<script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var swiper = new Swiper(".ClientSwiper", {
        slidesPerView: 3,
        spaceBetween: 30,
        loop: true,
        centeredSlides: true,
        autoplay: {
          delay: 3000,
          disableOnInteraction: false,
        },
        breakpoints: {
          640: {
            slidesPerView: 5,
            spaceBetween: 20,
          },
          850: {
            slidesPerView: 7,
            spaceBetween: 20,
          },
        },
      });
    });
</script>
