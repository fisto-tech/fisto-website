---
// AppPattern.astro
import ProductCustomizer from './ProductCustomizer.jsx';
---

<div class="app-pattern-container">
  <ProductCustomizer client:only="react" />
</div>

<style>
.app-pattern-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
  background: #0f172a; /* Dark minimal base */
  color: #fff;
  font-family: system-ui, -apple-system, sans-serif;
  overflow: hidden;
  border-radius: 38px; /* Match phone frame corner radius */
}

/* Desktop overrides */
:global(.phone-frame.desktop-mode .app-pattern-container) {
  border-radius: 12px;
  position: relative;
}
:global(.phone-frame.desktop-mode .app-pattern-container > div) {
  display: block !important;
}
:global(.phone-frame.desktop-mode .product-view) {
  position: absolute !important;
  top: 0;
  left: 0;
  width: 100%;
  height: 100% !important;
  z-index: 1;
}
:global(.phone-frame.desktop-mode .customizer-ui) {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: auto !important;
  background: transparent !important;
  border: none !important;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: flex-start;
  padding: 20px !important;
  z-index: 2;
  pointer-events: none;
}
:global(.phone-frame.desktop-mode .customizer-ui > *) {
  pointer-events: auto;
}
:global(.phone-frame.desktop-mode .customizer-ui h3) {
  text-shadow: 0 1px 4px rgba(0,0,0,0.8);
}
:global(.phone-frame.desktop-mode .customizer-ui button) {
  position: absolute;
  bottom: 20px;
  right: 20px;
  width: fit-content !important;
  padding: 10px 24px !important;
  font-size: 14px !important;
  border-radius: 8px !important;
  margin-top: 0 !important;
}
</style>
