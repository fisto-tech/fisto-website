---
// AppPattern.astro
import ProductCustomizer from './ProductCustomizer.jsx';
---

<div class="app-pattern-container">
  <ProductCustomizer client:only="react" />
</div>

<style>
.app-pattern-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
  background: #0f172a; /* Dark minimal base */
  color: #fff;
  font-family: system-ui, -apple-system, sans-serif;
  overflow: hidden;
  border-radius: 38px; /* Match phone frame corner radius */
}
</style>
