---
export interface Props {
  imageBefore?: string; 
  imageAfter?: string;
}

const { imageBefore, imageAfter } = Astro.props;
---

<section class="scroll-reveal-section">
  <div class="scroll-reveal-container" id="scrollRevealContainer">
    <!-- Image 2 (Background - always visible on the left) -->
    <img src={imageAfter || "/images/services/AR-VR/normal-world-img.webp"} alt="After Image" class="reveal-bg-img" />
    <div class="bg-gradient-overlay"></div>
    
    <!-- Image 1 (Foreground - slides in on the right half) -->
    <div class="reveal-fg-wrapper" id="revealFgWrapper">
      <img src={imageBefore || "/images/services/AR-VR/AR-world-img.webp"} alt="Before Image" class="reveal-fg-img" />
    </div>

    <!-- The vertical white reveal line -->
    <div class="reveal-line" id="revealLine"></div>

    <!-- Centralized Text Container, perfectly aligned to the left side -->
    <div class="reveal-text-container" id="revealTextContainer">
      <h2 class="main-title">
        <span class="text-white">See Every Dish</span><br/>
        <span class="text-yellow">Before You</span><br/>
        <span class="text-yellow">Place Your Order</span>
      </h2>
      
      <div class="divider"></div>
      
      <p class="description">
        Scan the QR code to explore<br/>
        Your restaurant menu in<br/>
        immersive <span class="text-yellow">Augmented Reality.</span>
      </p>
      
      <button class="scan-btn" id="qrTriggerBtn">
        <img src="/images/services/AR-VR/qr-icon.webp" alt="QR Icon" class="qr-icon" />
        <span class="btn-text">SCAN NOW</span>
        <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

    <!-- QR Code Modal Popup -->
    <div class="qr-modal-overlay" id="qrModalOverlay">
      <div class="qr-modal-content">
        <button class="qr-modal-close" id="qrModalClose">&times;</button>
        <div class="qr-modal-header">
          <h3>Experience AR Now</h3>
          <p>Point your phone camera at the QR code below</p>
        </div>
        <div class="qr-modal-body">
          <div class="qr-scanner-frame">
            <!-- Dynamic placeholder QR code that will actually scan to text -->
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=Fist-O-AR-Experience" alt="AR QR Code" class="qr-code-img" loading="lazy" />
            <div class="scanner-line"></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap');

.scroll-reveal-section {
  width: 100%;
  background-color: #000;
  position: relative;
  font-family: 'Inter', sans-serif;
}

.scroll-reveal-container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: flex-start; 
}

.reveal-bg-img,
.reveal-fg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  pointer-events: none;
}

.reveal-bg-img {
  /* Full opacity, darkening handled by overlay */
}

.bg-gradient-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.6) 40%, rgba(0,0,0,0) 70%);
  pointer-events: none;
  z-index: 1;
}

.reveal-fg-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  clip-path: inset(0 0 0 100%);
  will-change: clip-path;
}

.reveal-line {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 100%;
  width: 5px;
  background-color: #ffffff;
  transform: translateX(-50%);
  z-index: 10;
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.8), 0 0 30px rgba(255, 255, 255, 0.3);
  will-change: left;
}

.reveal-text-container {
  position: absolute;
  top: 50%;
  left: 5%;
  transform: translateY(-50%);
  width: 50%;
  z-index: 20;
  color: white;
}

.main-title {
  font-family: 'Oswald', 'Impact', sans-serif;
  font-size: clamp(3rem, 5vw, 5.5rem);
  line-height: 1.05;
  text-transform: capitalize;
  margin-bottom: 30px;
  letter-spacing: -0.02em;
}

.text-white { color: #ffffff; }
.text-yellow { color: #fbb03b; }

.divider {
  width: 60px;
  height: 2px;
  background-color: #fbb03b;
  margin-bottom: 30px;
}

.description {
  color: #e0e0e0;
  font-size: clamp(1.1rem, 1.5vw, 1.4rem);
  line-height: 1.4;
  margin-bottom: 40px;
  font-weight: 400;
}

.scan-btn {
  display: inline-flex;
  align-items: center;
  gap: 15px;
  background-color: rgba(0, 0, 0, 0.6);
  border: 1.5px solid #fbb03b;
  border-radius: 12px;
  padding: 12px 24px;
  cursor: pointer;
  transition: all 0.3s ease;
  pointer-events: auto;
  animation: pulse-button 2s infinite ease-in-out;
}

@keyframes pulse-button {
  0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(251, 176, 59, 0.4); }
  50% { transform: scale(1.05); box-shadow: 0 0 15px 5px rgba(251, 176, 59, 0.2); }
  100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(251, 176, 59, 0); }
}

.scan-btn:hover {
  background-color: rgba(251, 176, 59, 0.15);
  animation-play-state: paused;
}

.qr-icon {
  width: 24px;
  height: 24px;
  object-fit: contain;
}

.btn-text {
  color: #fbb03b;
  font-weight: 700;
  font-size: 1.1rem;
  letter-spacing: 0.5px;
}

.arrow-icon {
  width: 20px;
  height: 20px;
  color: #ffffff;
}

/* Modal CSS exactly as before */
.qr-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.4s ease;
  backdrop-filter: blur(8px);
}
.qr-modal-overlay.active {
  opacity: 1;
  visibility: visible;
}
.qr-modal-content {
  background: #040e1b;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  padding: 40px;
  max-width: 400px;
  width: 90%;
  text-align: center;
  position: relative;
  transform: translateY(30px) scale(0.95);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
}
.qr-modal-overlay.active .qr-modal-content {
  transform: translateY(0) scale(1);
}
.qr-modal-close {
  position: absolute;
  top: 15px;
  right: 15px;
  background: none;
  border: none;
  color: #ffffff;
  font-size: 28px;
  cursor: pointer;
  opacity: 0.6;
  transition: opacity 0.3s ease;
}
.qr-modal-close:hover {
  opacity: 1;
}
.qr-modal-header h3 {
  color: #ffffff;
  font-size: 1.5rem;
  margin-bottom: 10px;
}
.qr-modal-header p {
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.95rem;
  margin-bottom: 30px;
}
.qr-scanner-frame {
  position: relative;
  display: inline-block;
  padding: 15px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 15px;
  overflow: hidden;
}
.qr-code-img {
  display: block;
  width: 220px;
  height: 220px;
  border-radius: 10px;
}
.scanner-line {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: #ffffff;
  box-shadow: 0 0 15px 2px rgba(255, 255, 255, 0.8);
  animation: scanLine 2s ease-in-out infinite;
}
@keyframes scanLine {
  0% { top: 0; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { top: 100%; opacity: 0; }
}

@media (max-width: 1024px) {
  .reveal-text-container {
    width: 80%;
  }
}

@media (max-width: 768px) {
  .reveal-text-container {
    left: 50%;
    transform: translate(-50%, -50%);
    width: 95%;
  }
}
</style>

<script>
  let isInitialized = false;

  const initRevealScript = () => {
    if (isInitialized) return;

    if (typeof (window as any).gsap !== 'undefined' && typeof (window as any).ScrollTrigger !== 'undefined') {
      isInitialized = true;
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      
      gsap.registerPlugin(ScrollTrigger);

      const container = document.getElementById('scrollRevealContainer');
      const fgWrapper = document.getElementById('revealFgWrapper');
      const revealLine = document.getElementById('revealLine');
      
      const titleEl = document.querySelector('.main-title');
      const descEl = document.querySelector('.description');
      const btnEl = document.querySelector('.scan-btn');
      const dividerEl = document.querySelector('.divider');

      if (container && fgWrapper && revealLine && titleEl) {
        
        gsap.set([titleEl, dividerEl, descEl], { opacity: 0, y: 30 });

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: container,
            start: "top top",
            end: "+=200%", 
            pin: true,
            scrub: 1, 
            pinSpacing: true
          }
        });

        // 1. First scroll reveal: Fade in title and divider
        tl.to([titleEl, dividerEl], {
          opacity: 1,
          y: 0,
          ease: "power2.out",
          duration: 0.3
        }, 0);

        // 2. Second scroll reveal: Fade in description
        tl.to(descEl, {
          opacity: 1,
          y: 0,
          ease: "power2.out",
          duration: 0.3
        }, 0.2);

        // 3. Reveal image strictly on the right half (from 100% clipped to 50% clipped)
        tl.to(fgWrapper, {
          clipPath: "inset(0 0 0 50%)",
          ease: "none",
          duration: 1
        }, 0);
        
        // 3. Line sync (moves from 100% right edge to 50% center)
        tl.to(revealLine, {
          left: "50%",
          ease: "none",
          duration: 1
        }, 0);

        ScrollTrigger.sort();
        ScrollTrigger.refresh();
      }
    } else {
      setTimeout(initRevealScript, 100);
    }
  };

  // QR Modal Logic
  const initQrModal = () => {
    const btn = document.getElementById('qrTriggerBtn');
    const modal = document.getElementById('qrModalOverlay');
    const closeBtn = document.getElementById('qrModalClose');

    if (btn && modal && closeBtn) {
      const newBtn = btn.cloneNode(true);
      btn.parentNode?.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', () => {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
      
      closeBtn.addEventListener('click', () => {
        modal.classList.remove('active');
        document.body.style.overflow = '';
      });
      
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('active');
          document.body.style.overflow = '';
        }
      });
    }
  };

  document.addEventListener("DOMContentLoaded", () => {
    initRevealScript();
    initQrModal();
  });
  
  if (
    document.readyState === "interactive" ||
    document.readyState === "complete"
  ) {
    initRevealScript();
    initQrModal();
  }
</script>
