---
export interface Props {
  imageBefore: string;
  imageAfter: string;
}

const { imageBefore, imageAfter } = Astro.props;
---

<section class="image-reveal-section">
  <div class="image-reveal-container" id="imageRevealContainer">
    <!-- Base Image (Normal World) -->
    <img src={imageBefore} alt="Normal World" class="image-reveal-before" />
    
    <!-- Top Image (AR World) - Clipped -->
    <img src={imageAfter} alt="AR World" class="image-reveal-after" id="imageRevealAfter" />

    <!-- Interactive Reveal Line -->
    <div class="image-reveal-slider" id="imageRevealSlider">
      <!-- Invisible hit area for easier grabbing -->
      <div class="image-reveal-hitbox"></div>
      <div class="image-reveal-handle"></div>
    </div>
  </div>
</section>

<style>
.image-reveal-section {
  width: 100%;
  height: 100vh;
  min-height: 600px;
  background-color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.image-reveal-container {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  /* Prevent text selection while dragging */
  user-select: none;
  -webkit-user-select: none;
  touch-action: none; /* Prevent scrolling while swiping horizontally on mobile */
}

.image-reveal-before,
.image-reveal-after {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  pointer-events: none;
}

/* Initially clip the top image to exactly 50% */
.image-reveal-after {
  clip-path: inset(0 50% 0 0);
}

/* The vertical reveal line */
.image-reveal-slider {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 2px;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 1) 15%, rgba(255, 255, 255, 1) 85%, rgba(255, 255, 255, 0) 100%);
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.6), 0 0 30px rgba(0, 212, 255, 0.4);
  transform: translateX(-50%);
  z-index: 10;
}

/* Invisible hit area for the slider so it's easy to grab on mobile/desktop */
.image-reveal-hitbox {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -24px;
  right: -24px;
  cursor: ew-resize;
  z-index: 1;
}

/* Minimal glowing handle */
.image-reveal-handle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-shadow: 0 0 20px rgba(0, 212, 255, 0.5), inset 0 0 10px rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: ew-resize;
  z-index: 2;
}

/* Left and right arrows inside handle */
.image-reveal-handle::before,
.image-reveal-handle::after {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-style: solid;
}

.image-reveal-handle::before {
  border-width: 5px 6px 5px 0;
  border-color: transparent rgba(255, 255, 255, 0.9) transparent transparent;
  left: 10px;
}
.image-reveal-handle::after {
  border-width: 5px 0 5px 6px;
  border-color: transparent transparent transparent rgba(255, 255, 255, 0.9);
  right: 10px;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('imageRevealContainer');
  const slider = document.getElementById('imageRevealSlider');
  const afterImage = document.getElementById('imageRevealAfter');

  if (!container || !slider || !afterImage) return;

  let isInteracted = false;
  let isDragging = false;
  let currentPercentage = 50;
  let targetPercentage = 50;
  
  // Animation timing
  const startTime = Date.now();

  // LERP for smooth easing
  const lerp = (start, end, factor) => {
    return start + (end - start) * factor;
  };

  const calculateTarget = (clientX) => {
    const rect = container.getBoundingClientRect();
    let x = clientX - rect.left;

    // Clamp values
    if (x < 0) x = 0;
    if (x > rect.width) x = rect.width;

    return (x / rect.width) * 100;
  };

  const animationLoop = () => {
    // If not interacted with, slowly oscillate between 20% and 80% (i.e., 30% from edges)
    if (!isInteracted) {
      const timeElapsed = Date.now() - startTime;
      // Math.sin oscillates between -1 and 1. Multiply by 30 for a 60% total swing (50-30=20 to 50+30=80)
      // Dividing by 1500 slows it down.
      targetPercentage = 50 + Math.sin(timeElapsed / 1500) * 30;
    }

    // Always lerp towards target for smooth movement
    currentPercentage = lerp(currentPercentage, targetPercentage, isInteracted ? 0.15 : 0.03);
    
    slider.style.left = `${currentPercentage}%`;
    afterImage.style.clipPath = `inset(0 ${100 - currentPercentage}% 0 0)`;
    
    requestAnimationFrame(animationLoop);
  };

  // Start the render loop
  requestAnimationFrame(animationLoop);

  // Stop auto-animation and start dragging
  const startDrag = (clientX) => {
    isInteracted = true;
    isDragging = true;
    targetPercentage = calculateTarget(clientX);
  };

  // Handle Dragging
  const handleDrag = (clientX) => {
    if (isDragging) {
      targetPercentage = calculateTarget(clientX);
    }
  };

  const stopDrag = () => {
    isDragging = false;
  };

  // --- Desktop Events ---
  // Only start dragging if mousedown happens on the slider (hitbox or handle)
  slider.addEventListener('mousedown', (e) => {
    startDrag(e.clientX);
  });
  
  window.addEventListener('mousemove', (e) => {
    handleDrag(e.clientX);
  });
  
  window.addEventListener('mouseup', () => {
    stopDrag();
  });

  // --- Mobile Events ---
  // Only start dragging if touchstart happens on the slider
  slider.addEventListener('touchstart', (e) => {
    startDrag(e.touches[0].clientX);
  }, { passive: false });

  window.addEventListener('touchmove', (e) => {
    handleDrag(e.touches[0].clientX);
  }, { passive: false });

  window.addEventListener('touchend', () => {
    stopDrag();
  });
});
</script>
