---
export interface Props {
  imageBefore: string;
  imageAfter: string;
}

const { imageBefore, imageAfter } = Astro.props;
---

<section class="scroll-reveal-section">
  <div class="scroll-reveal-container" id="scrollRevealContainer">
    <!-- Image 2 (Background - fully visible at all times) -->
    <img src={imageAfter} alt="After Image" class="reveal-bg-img" />
    
    <!-- Image 1 (Foreground - initially covers background) -->
    <div class="reveal-fg-wrapper" id="revealFgWrapper">
      <img src={imageBefore} alt="Before Image" class="reveal-fg-img" />
    </div>

    <!-- The vertical white reveal line -->
    <div class="reveal-line" id="revealLine"></div>
  </div>
</section>

<style>
.scroll-reveal-section {
  width: 100%;
  background-color: #000;
  position: relative;
}

.scroll-reveal-container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reveal-bg-img,
.reveal-fg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  pointer-events: none;
}

.reveal-fg-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  /* Initially 0% clipped from left */
  clip-path: inset(0 0 0 0%);
  /* Will-change for better performance during animation */
  will-change: clip-path;
}

.reveal-line {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0%;
  width: 5px; /* 4-6px wide as requested */
  background-color: #ffffff;
  /* Shift left by 50% of its own width so it centers exactly on the boundary */
  transform: translateX(-50%);
  z-index: 10;
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.8), 0 0 30px rgba(255, 255, 255, 0.3);
  will-change: left;
}
</style>

<script>
  let isInitialized = false;

  // Setup GSAP ScrollTrigger for the reveal effect
  const initRevealAnimation = () => {
    if (isInitialized) return;

    // Ensure GSAP is loaded
    if (typeof window.gsap !== 'undefined' && typeof window.ScrollTrigger !== 'undefined') {
      isInitialized = true;
      const gsap = window.gsap;
      const ScrollTrigger = window.ScrollTrigger;
      
      gsap.registerPlugin(ScrollTrigger);

      const container = document.getElementById('scrollRevealContainer');
      const fgWrapper = document.getElementById('revealFgWrapper');
      const revealLine = document.getElementById('revealLine');

      if (container && fgWrapper && revealLine) {
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: container,
            start: "top top",
            // Pin the container for 150% of viewport height while animating
            end: "+=150%", 
            pin: true,
            scrub: 1, // Smooth scrubbing linking animation directly to scrollbar
            // Prevent layout shifts during pin
            pinSpacing: true
          }
        });

        // Animate the clip-path from left to right (0% to 100%)
        tl.to(fgWrapper, {
          clipPath: "inset(0 0 0 100%)",
          ease: "none",
          duration: 1
        }, 0);

        // Animate the reveal line matching the clip-path
        tl.to(revealLine, {
          left: "100%",
          ease: "none",
          duration: 1
        }, 0);

        // Crucial Fix: Since we created the pin AFTER main.js created the footer triggers,
        // we must sort the triggers by DOM order before refreshing. Otherwise, the footer 
        // trigger refreshes before the pin adds its spacer, resulting in wrong coordinates!
        ScrollTrigger.sort();
        ScrollTrigger.refresh();
      }
    } else {
      // Retry if gsap is not yet loaded
      setTimeout(initRevealAnimation, 100);
    }
  };

  document.addEventListener('DOMContentLoaded', initRevealAnimation);
  // Also run immediately in case DOMContentLoaded already fired (common in Astro)
  if (document.readyState === 'interactive' || document.readyState === 'complete') {
    initRevealAnimation();
  }
</script>
