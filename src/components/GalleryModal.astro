---
export interface GalleryItem {
  title: string;
  image: string;
  video: string; // URL for the 5-10s preview
}

export interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

<div id="gallery-modal" class="gallery-modal hidden">
  <div class="gallery-modal__backdrop" id="gallery-modal-close-bg"></div>
  <div class="gallery-modal__content">
    
    <div class="gallery-modal__header">
      <h2>3D Website Demos</h2>
      <button id="gallery-modal-close" class="gallery-modal__close" aria-label="Close Gallery">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

    <div class="gallery-grid">
      {items.map((item, idx) => (
        <div class="gallery-card" data-video-src={item.video}>
          <div class="gallery-card__media">
            <!-- Thumbnail Image (always present) -->
            <img src={item.image} alt={item.title} class="gallery-card__image" loading="lazy" />
            <!-- Video (injected/played on hover) -->
            <video 
              class="gallery-card__video hidden" 
              muted 
              loop 
              playsinline
              preload="none"
            >
              <source src={item.video} type="video/mp4" />
            </video>
          </div>
          <div class="gallery-card__info">
            <h3>{item.title}</h3>
          </div>
        </div>
      ))}
    </div>

  </div>
</div>

<style>
.hidden {
  display: none !important;
}

.gallery-modal {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gallery-modal__backdrop {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(8px);
}

.gallery-modal__content {
  position: relative;
  z-index: 10;
  width: 90%;
  max-width: 1200px;
  height: 90vh;
  background-color: #112025; /* Dark premium theme */
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  animation: modalIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes modalIn {
  from { opacity: 0; transform: translateY(20px) scale(0.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.gallery-modal__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 2rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.gallery-modal__header h2 {
  color: #fff;
  font-size: 1.5rem;
  font-weight: 600;
  margin: 0;
}

.gallery-modal__close {
  background: rgba(255,255,255,0.1);
  border: none;
  color: #fff;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}

.gallery-modal__close:hover {
  background: rgba(255,255,255,0.2);
  transform: scale(1.05);
}

.gallery-grid {
  padding: 2rem;
  overflow-y: auto;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 2rem;
  /* Customize scrollbar for dark theme */
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.3) transparent;
}

.gallery-grid::-webkit-scrollbar {
  width: 8px;
}
.gallery-grid::-webkit-scrollbar-track {
  background: transparent;
}
.gallery-grid::-webkit-scrollbar-thumb {
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 4px;
}

.gallery-card {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  cursor: pointer;
}

.gallery-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  border-color: rgba(255, 255, 255, 0.2);
}

.gallery-card__media {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: #000;
}

.gallery-card__image,
.gallery-card__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  position: absolute;
  top: 0;
  left: 0;
  transition: opacity 0.4s ease;
}

/* When the video is active, hide the image to avoid weird overlaps, or just put video on top.
   Video on top is easier. */
.gallery-card__video {
  z-index: 2;
  opacity: 0;
}

.gallery-card.is-hovered .gallery-card__video {
  opacity: 1;
}

.gallery-card__info {
  padding: 1.25rem;
}

.gallery-card__info h3 {
  color: #fff;
  font-size: 1.1rem;
  font-weight: 500;
  margin: 0;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const modal = document.getElementById('gallery-modal');
  const closeBtn = document.getElementById('gallery-modal-close');
  const closeBg = document.getElementById('gallery-modal-close-bg');
  
  // Close logic
  const closeModal = () => {
    if (modal) modal.classList.add('hidden');
    document.body.style.overflow = ''; // Restore scroll
  };

  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (closeBg) closeBg.addEventListener('click', closeModal);

  // Expose open logic globally so the "View More" button on the page can trigger it
  (window as any).openGalleryModal = () => {
    if (modal) {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }
  };

  // Hover logic for cards
  const cards = document.querySelectorAll('.gallery-card');
  
  cards.forEach(card => {
    const video = card.querySelector('.gallery-card__video') as HTMLVideoElement;
    
    if (video) {
      // We only load the video on hover to save bandwidth
      card.addEventListener('mouseenter', () => {
        card.classList.add('is-hovered');
        if (video.readyState === 0) {
          video.load(); // Lazy load the video
        }
        
        const playPromise = video.play();
        if (playPromise !== undefined) {
          playPromise.catch((error: any) => {
            // Autoplay might be blocked, ignore
            console.log("Autoplay blocked or interrupted");
          });
        }
      });

      card.addEventListener('mouseleave', () => {
        card.classList.remove('is-hovered');
        video.pause();
        video.currentTime = 0; // Reset to start
      });
    }
  });
});
</script>
