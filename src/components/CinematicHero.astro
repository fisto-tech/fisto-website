// src/components/CinematicHero.astro
---

<section class="cinematic-hero-section" id="cinematicHero">
  <div class="hero-container">
    <div class="slide">
      
      <!-- ITEM 1: AR -->
      <div class="item">
        <video muted loop playsinline class="item-video" preload="auto">
          <source src="/images/services/AR-VR/AR-video.mp4" type="video/mp4" />
