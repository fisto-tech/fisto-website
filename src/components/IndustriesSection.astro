---
// src/components/IndustriesSection.astro
---

<section class="industries-section">
  <div class="container">
    <div class="section-header">
      <h2 style="font-size: 2.5rem; font-weight: 800; color: #000000;">AR Across Industries</h2>
      <p>Elevating Efficiency with Advanced Technology</p>
    </div>

    <div class="industries-grid">
      <!-- Industry Item 1 -->
      <div class="industry-card">
        <div class="icon-wrapper">
          <img
            src="/images/services/AR-VR/manufacturing.webp"
            alt="Manufacturing"
            loading="lazy"
          />
        </div>
        <h3>Manufacturing</h3>
      </div>

      <!-- Industry Item 2 -->
      <div class="industry-card">
        <div class="icon-wrapper">
          <img
            src="/images/services/AR-VR/education.webp"
            alt="Education"
            loading="lazy"
          />
        </div>
        <h3>Education</h3>
      </div>

      <!-- Industry Item 3 -->
      <div class="industry-card">
        <div class="icon-wrapper">
          <img
            src="/images/services/AR-VR/jewellery.webp"
            alt="Ornaments"
            loading="lazy"
          />
        </div>
        <h3>Ornaments</h3>
      </div>

      <!-- Industry Item 4 -->
      <div class="industry-card">
        <div class="icon-wrapper">
          <img
            src="/images/services/AR-VR/foods.webp"
            alt="Foods"
            loading="lazy"
          />
        </div>
        <h3>Foods</h3>
      </div>

      <!-- Industry Item 5 -->
      <div class="industry-card">
        <div class="icon-wrapper">
          <img
            src="/images/services/AR-VR/textile.webp"
            alt="Textiles"
            loading="lazy"
          />
        </div>
        <h3>Textiles</h3>
      </div>

      <!-- Industry Item 6 -->
      <div class="industry-card">
        <div class="icon-wrapper">
          <img
            src="/images/services/AR-VR/real estate.webp"
            alt="Real Estate"
            loading="lazy"
          />
        </div>
        <h3>Real Estate</h3>
      </div>

      <!-- Industry Item 7 -->
      <div class="industry-card">
        <div class="icon-wrapper">
          <img
            src="/images/services/AR-VR/socialmedia.webp"
            alt="Social Media"
            loading="lazy"
          />
        </div>
        <h3>Social Media</h3>
      </div>
    </div>
  </div>
</section>

<style>
  .industries-section {
    padding: 100px 20px;
    background-color: var(
      --bg,
      #ffffff
    ); /* Using theme variable with fallback */
    color: var(--text-primary, #112025);
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-header h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 15px;
    position: relative;
    display: inline-block;
    letter-spacing: -0.02em;
    padding-bottom: 0.1em;
  }

  .section-header h2 .char {
    display: inline-block;
    white-space: pre;
    will-change: transform, opacity, background;
  }

  /* Stylized graphic element behind "Industries" to match the screenshot vibe */
  .highlight {
    position: relative;
    display: inline-block;
    z-index: 1;
  }
  .highlight::before {
    content: "";
    position: absolute;
    top: -10px;
    left: -15px;
    width: 40px;
    height: 120%;
    border-top: 4px solid #3b82f6; /* Blue accent */
    border-left: 4px solid #3b82f6;
    border-bottom: 4px solid #3b82f6;
    opacity: 0.5;
    z-index: -1;
    border-radius: 4px 0 0 4px;
  }

  .section-header p {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-secondary, #2a5f6e);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Grid Layout */
  .industries-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 30px;
    justify-content: center;
  }

  /* Cards styling & Hover Effects */
  .industry-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 15px;
    cursor: pointer;
    group: industry; /* For hover propagation if needed */
  }

  .icon-wrapper {
    width: 100%;
    aspect-ratio: 1;
    max-width: 140px;
    /* background: #ffffff;
    border-radius: 20px;
    border: 2px solid rgba(14, 116, 144, 0.1); */
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 25px;
    /* box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); */
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
  }

  .icon-wrapper::before {
    content: "";
    position: absolute;
    inset: 0;
    /* background: linear-gradient(135deg, rgba(14, 116, 144, 0.1), rgba(34, 211, 238, 0.05)); */
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .icon-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition:
      transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      filter 0.3s ease;
    position: relative;
    z-index: 2;
    /* Optional: If the PNGs are black, a CSS filter can add a theme color on hover */
  }

  .industry-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary, #1e4550);
    transition: color 0.3s ease;
    margin: 0;
  }

  /* HOVER EFFECTS */
  .industry-card:hover .icon-wrapper {
    transform: translateY(-10px);
    border-color: var(--accent, #0e7490);
    /* box-shadow: 0 15px 35px rgba(14, 116, 144, 0.15); */
  }

  .industry-card:hover .icon-wrapper::before {
    opacity: 1;
  }

  .industry-card:hover .icon-wrapper img {
    transform: scale(1.15);
    /* Attempt to colorize the icon on hover if it's black/white */
    /* filter: drop-shadow(0px 4px 6px rgba(14, 116, 144, 0.3));  */
  }

  .industry-card:hover h3 {
    color: var(--accent, #0e7490);
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .industries-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .icon-wrapper {
      padding: 20px;
    }
  }

  @media (max-width: 480px) {
    .industries-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }

    .section-header {
      margin-bottom: 40px;
    }
  }
</style>

<script>
  let industriesInitialized = false;

  const initIndustriesAnim = () => {
    if (industriesInitialized) return;
    if (
      typeof (window as any).gsap !== "undefined" &&
      typeof (window as any).ScrollTrigger !== "undefined"
    ) {
      industriesInitialized = true;
      const gsap = (window as any).gsap;

      const cards = gsap.utils.toArray(".industry-card");

      // Set initial state
      gsap.set(cards, { scale: 0.5, opacity: 0, y: 50 });

      // Animate on scroll
      gsap.to(cards, {
        scrollTrigger: {
          trigger: ".industries-grid",
          start: "top 85%", // Start when grid is 15% into viewport
          toggleActions: "play reverse play reverse",
        },
        scale: 1,
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.1, // Reveal one by one
        ease: "back.out(1.5)", // Popup effect
      });
    } else {
      setTimeout(initIndustriesAnim, 100);
    }
  };

  document.addEventListener("DOMContentLoaded", initIndustriesAnim);
  if (
    document.readyState === "interactive" ||
    document.readyState === "complete"
  ) {
    initIndustriesAnim();
  }
</script>
