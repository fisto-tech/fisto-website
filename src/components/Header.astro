---
const { current = "" } = Astro.props;

function isActive(name) {
  return name.toLowerCase() === current.toLowerCase() ? "active" : "";
}

function isServiceActive() {
  const services = ["ar-vr-mr", "2d-3d-animation", "idc", "customized-applications", "3d-website"];
  return services.includes(current.toLowerCase()) ? "active-parent" : "";
}
