.benefits-container {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 5rem;
  position: relative;
  z-index: 1; /* Ensure content is above parallax ingredients */
}

/* Section Header */
.benefits-header {
  text-align: center;
  margin-bottom: 2rem;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}

.benefits-main-title {
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  font-weight: 900;
  color: #040e1b;
  margin-bottom: 1rem;
  letter-spacing: -0.02em;
}

.highlight-cyan {
  color: #22d3ee;
}

.benefits-main-subtitle {
  font-size: 1.25rem;
  color: #555;
  line-height: 1.6;
}

.benefit-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
  border-bottom: 1px solid rgba(0,0,0,0.05);
  padding-bottom: 5rem;
}
.benefit-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

@media (min-width: 768px) {
  .benefit-row {
    flex-direction: row;
    gap: 4rem;
    justify-content: space-between;
  }
}

.benefit-text {
  flex: 1;
  text-align: center;
}

@media (min-width: 768px) {
  .row-left .benefit-text { 
    text-align: left; 
    padding-right: 2rem;
  }
  .row-right .benefit-text { 
    text-align: left; 
    padding-left: 2rem;
  }
}

.benefit-title {
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  font-weight: 800;
  margin-bottom: 1rem;
  color: #111;
  letter-spacing: -0.02em;
}

.benefit-desc {
  font-size: 1.15rem;
  color: #555;
  line-height: 1.6;
}

.benefit-number-container {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  filter: drop-shadow(0 20px 30px rgba(0,0,0,0.15));
}

@media (max-width: 767px) {
  /* On mobile, ensure the image is always below the text for consistency, even for right-aligned rows */
  .mobile-flip {
    order: 2;
  }
}

.benefit-number {
  font-size: clamp(10rem, 25vw, 22rem);
  font-weight: 900;
  line-height: 1;
  padding: 0 10px;
  letter-spacing: 0.05em; /* Added gap between numbers */
  font-family: 'Inter', sans-serif;
  
  /* Masking the image inside the text */
  background-color: #333; /* Fallback */
  background-size: cover;
  background-position: center;
  color: transparent;
  -webkit-background-clip: text;
  background-clip: text;
  display: inline-block;
}

/* Base states for independent GSAP animations */
.benefit-row .benefit-text,
.benefit-row .benefit-number-container {
  opacity: 0;
  will-change: transform, opacity;
}

/* Initial positions based on layout side */
.benefit-row.row-left .benefit-text { transform: translateX(-60px); }
.benefit-row.row-left .benefit-number-container { transform: translateX(60px); }

.benefit-row.row-right .benefit-number-container { transform: translateX(-60px); }
.benefit-row.row-right .benefit-text { transform: translateX(60px); }

@media (max-width: 767px) {
  /* On mobile, slide everything from the bottom up instead of sides to prevent overflow issues */
  .benefit-row .benefit-text,
  .benefit-row .benefit-number-container {
    transform: translateY(40px) !important; 
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const gsap = (window as any).gsap;
  const ScrollTrigger = (window as any).ScrollTrigger;

  if (gsap && ScrollTrigger) {
    gsap.registerPlugin(ScrollTrigger);

    const rows = document.querySelectorAll('.benefit-row');
    rows.forEach((row, i) => {
      const text = row.querySelector('.benefit-text');
      const number = row.querySelector('.benefit-number-container');
      
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: row,
          start: "top 85%", 
          toggleActions: "play none none reverse"
        }
      });

      // Animate text and number with a slight stagger
      tl.to([text, number], {
        x: 0,
        y: 0,
        opacity: 1,
        duration: 1.2,
        ease: "power3.out",
        stagger: 0.2 // Stagger the two elements
      });
    });

    // Parallax Ingredients animation removed
  }
});
</script>
