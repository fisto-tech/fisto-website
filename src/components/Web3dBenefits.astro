---
// Web3dBenefits.astro
---

<section class="benefits-section">
  <!-- Floating shapes removed as per user request -->

  <div class="benefits-container">
    
    <!-- Section Header -->
    <div class="benefits-header" data-aos="fade-up">
      <h2 class="benefits-main-title">Why Choose <span class="highlight-cyan">3D Websites?</span></h2>
      <p class="benefits-main-subtitle">Discover how immersive web technologies can transform your digital presence, captivate your audience, and drive real business results.</p>
    </div>
    
    <!-- Row 1 -->
    <div class="benefit-row row-left benefit-anim">
      <div class="benefit-text">
        <h3 class="benefit-title">Interactive 3D Visual Experiences</h3>
        <p class="benefit-desc">Create engaging websites with interactive 3D objects, animations, and environments that allow users to explore your brand in an innovative way.</p>
      </div>
      <div class="benefit-number-container">
        <div class="benefit-number" style="background-image: url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&w=800&q=80');">01</div>
      </div>
    </div>

    <!-- Row 2 -->
    <div class="benefit-row row-right benefit-anim">
      <div class="benefit-number-container mobile-flip">
        <div class="benefit-number" style="background-image: url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=800&q=80');">02</div>
      </div>
      <div class="benefit-text">
        <h3 class="benefit-title">Realistic 3D Product Visualization</h3>
        <p class="benefit-desc">Showcase your products with detailed 3D models that allow customers to view, rotate, and interact with products from different perspectives.</p>
      </div>
    </div>

    <!-- Row 3 -->
    <div class="benefit-row row-left benefit-anim">
      <div class="benefit-text">
        <h3 class="benefit-title">Immersive Website Animations</h3>
        <p class="benefit-desc">Enhance user experience with smooth transitions, motion effects, and interactive animations that make your website more engaging.</p>
      </div>
      <div class="benefit-number-container">
        <div class="benefit-number" style="background-image: url('https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?auto=format&fit=crop&w=800&q=80');">03</div>
      </div>
    </div>

    <!-- Row 4 -->
    <div class="benefit-row row-right benefit-anim">
      <div class="benefit-number-container mobile-flip">
        <div class="benefit-number" style="background-image: url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=800&q=80');">04</div>
      </div>
      <div class="benefit-text">
        <h3 class="benefit-title">Responsive 3D Website Design</h3>
        <p class="benefit-desc">Our 3D websites are optimized for desktops, tablets, and mobile devices to deliver seamless performance across all screen sizes.</p>
      </div>
    </div>

  </div>
</section>

<style>
.benefits-section {
  padding: 8rem 5%;
  background-color: #ffffff;
  color: #1a1a1a;
  overflow: hidden;
  position: relative;
}

/* Parallax Ingredients */
.parallax-ingredients {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.ingredient {
  position: absolute;
  font-size: 5rem;
  opacity: 0.6; /* Fully visible */
  filter: drop-shadow(0 20px 20px rgba(0,0,0,0.15));
}

.ingredient.cyan { color: #22d3ee; }
.ingredient.dark { color: #040e1b; opacity: 0.2; } /* Dark is a bit too strong at 0.6 */
.ingredient.yellow { color: #ffcb05; }

/* Position and depth of field blur */
.i-1 { top: 5%; left: 8%; font-size: 8rem; filter: blur(2px); }
.i-2 { top: 12%; right: 10%; font-size: 6rem; }
.i-3 { top: 25%; left: 15%; font-size: 4rem; filter: blur(1px); }
.i-4 { top: 38%; right: 8%; font-size: 7rem; filter: blur(3px); }
.i-5 { top: 52%; left: 10%; font-size: 9rem; }
.i-6 { top: 65%; right: 12%; font-size: 5.5rem; filter: blur(1px); }
.i-7 { top: 78%; left: 20%; font-size: 6rem; }
.i-8 { top: 92%; right: 15%; font-size: 8rem; filter: blur(2px); }
.i-9 { top: 8%; left: 40%; font-size: 3.5rem; filter: blur(1px); }
