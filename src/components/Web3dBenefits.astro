.i-15 { top: 88%; left: 35%; font-size: 5.5rem; filter: blur(1px); }
.i-16 { top: 95%; left: 25%; font-size: 6.5rem; filter: blur(2px); }
.i-17 { top: 3%; right: 25%; font-size: 4rem; filter: blur(1px); }
.i-18 { top: 18%; left: 25%; font-size: 7rem; }
.i-19 { top: 32%; right: 45%; font-size: 5rem; filter: blur(3px); }
.i-20 { top: 45%; left: 40%; font-size: 4rem; }
.i-21 { top: 58%; right: 25%; font-size: 6.5rem; filter: blur(1px); }
.i-22 { top: 72%; left: 28%; font-size: 5rem; }
.i-23 { top: 82%; right: 30%; font-size: 4.5rem; filter: blur(2px); }
.i-24 { top: 98%; right: 5%; font-size: 7rem; filter: blur(1px); }
.i-25 { top: 2%; left: 55%; font-size: 4rem; filter: blur(3px); }
.i-26 { top: 12%; right: 55%; font-size: 6.5rem; }
.i-27 { top: 28%; left: 65%; font-size: 5rem; filter: blur(1px); }
.i-28 { top: 42%; right: 60%; font-size: 8rem; filter: blur(2px); }
.i-29 { top: 55%; left: 55%; font-size: 4.5rem; filter: blur(4px); }
.i-30 { top: 68%; right: 50%; font-size: 6rem; filter: blur(1px); }
.i-31 { top: 78%; left: 60%; font-size: 7rem; }
.i-32 { top: 92%; right: 55%; font-size: 5.5rem; filter: blur(3px); }
.i-33 { top: 8%; left: 75%; font-size: 7.5rem; filter: blur(2px); }
.i-34 { top: 22%; right: 70%; font-size: 4rem; }
.i-35 { top: 38%; left: 80%; font-size: 6.5rem; filter: blur(1px); }
.i-36 { top: 52%; right: 75%; font-size: 5rem; filter: blur(3px); }
.i-37 { top: 65%; left: 70%; font-size: 8.5rem; filter: blur(2px); }
