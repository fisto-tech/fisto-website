---
const benefits = [
  {
    num: "01",
    title: "CREATIVE STORYTELLING",
    desc: "Fisto Tech develops visually compelling stories that simplify complex concepts and communicate your brand message effectively through professional animation.",
    color1: "#ff4b4b",
    color2: "#ff7676",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><line x1="7" y1="2" x2="7" y2="22"></line><line x1="17" y1="2" x2="17" y2="22"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="7" x2="7" y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="17" x2="22" y2="17"></line><line x1="17" y1="7" x2="22" y2="7"></line></svg>`
  },
  {
    num: "02",
    title: "REALISTIC 3D ANIMATION",
    desc: "We create detailed 3D animations with realistic models, textures, lighting, and cinematic effects for products, industries, architecture, and digital experiences.",
    color1: "#ff8f3d",
    color2: "#ffb476",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>`
  },
  {
    num: "03",
    title: "PRODUCT ANIMATION",
    desc: "Showcase your products with detailed 3D animations that highlight features, functionality, and benefits, helping customers better understand your offerings.",
    color1: "#4b7bff",
    color2: "#769bff",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>`
  },
  {
    num: "04",
    title: "CHARACTER ANIMATION",
    desc: "Our creative character animations bring ideas to life with expressive movements and engaging visuals for advertising, education, entertainment, and marketing campaigns.",
    color1: "#a84bff",
    color2: "#c476ff",
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`
  }
];
---

<section class="benefits-infographic">
  <!-- Optional subtle background elements to make the glass effect visible -->
  <div class="glass-bg-orb orb-1"></div>
  <div class="glass-bg-orb orb-2"></div>

  <div class="container">
    <div class="section-header">
      <h2 class="section-title js-animate-title">
        <span class="line-wrap"><span class="text-line shimmer-text" data-base="#ffffff" data-sweep="#08c098">Features of Our</span></span>
        <span class="line-wrap"><span class="text-line shimmer-text" data-base="#08c098" data-sweep="#ffffff">2D/3D ANIMATION</span></span>
        <span class="line-wrap"><span class="text-line shimmer-text" data-base="#ffffff" data-sweep="#08c098">Solutions</span></span>
      </h2>
    </div>

    <div class="cards-wrapper">
      {benefits.map((b, idx) => (
        <div class="info-card" style={`--delay: -${idx * 1.5}s; --dur: 6s;`}>
          <!-- The Glowing Outline Animation -->
          <svg class="outline-svg" viewBox="0 0 300 400" preserveAspectRatio="none">
            <defs>
              <linearGradient id={`grad-${b.num}`} x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color={b.color1} />
                <stop offset="100%" stop-color={b.color2} />
              </linearGradient>
            </defs>
            <rect 
              class="svg-rect glow" 
              x="2" y="2" width="296" height="396" rx="32" ry="32" 
              stroke={`url(#grad-${b.num})`} 
              pathLength="100"
            />
            <rect 
              class="svg-rect" 
              x="2" y="2" width="296" height="396" rx="32" ry="32" 
              stroke={`url(#grad-${b.num})`} 
              pathLength="100"
            />
          </svg>
          
          <!-- The Glass Card -->
          <div class="card-inner">
            <div class="icon-wrap" set:html={b.icon}></div>
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
            <div class="num" style={`color: ${b.color1};`}>{b.num}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .char {
    display: inline-block;
    white-space: pre-wrap;
  }

  .benefits-infographic {
    padding: 100px 20px 140px 20px;
    background: #050505; /* Matches the main site dark theme */
    color: #fff;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 992px) {
    .benefits-infographic {
      height: 100vh;
      padding: 0 20px;
    }
  }

  /* Orbs to give the glass something to blur/refract */
  .glass-bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
    z-index: 0;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: #ff4b4b;
    top: 10%;
    left: 15%;
  }

  .orb-2 {
    width: 500px;
    height: 500px;
    background: #4b7bff;
    bottom: -10%;
    right: 10%;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .section-title {
    font-size: clamp(2.5rem, 4.5vw, 3.5rem);
    font-family: 'Bebas Neue', 'Anton', sans-serif;
    font-weight: 700;
    color: #fff;
    margin: 0;
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .line-wrap {
    overflow: hidden;
    display: block;
  }

  .text-line {
    display: inline-block;
    will-change: transform;
    opacity: 0; /* Handled by GSAP */
  }

  .cards-wrapper {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .info-card {
    position: relative;
    width: 280px;
    height: 320px;
    margin-bottom: 30px;
    transition: transform 0.3s ease;
    cursor: pointer;
  }

  .info-card:hover {
    transform: translateY(-10px);
  }

  /* The Hyper-Realistic Glass Card */
  .card-inner {
    position: absolute;
    inset: 0;
    /* Semi-transparent gradient for a more realistic glass sheen */
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.02) 100%);
    /* Stronger blur and saturation for better light bending */
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    /* Slightly thicker rim light */
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 24px;
    padding: 30px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    /* Combining a dark drop shadow with a soft white inset shadow for 3D rim lighting */
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.2), 0 20px 40px rgba(0,0,0,0.4);
    z-index: 2;
  }

  .icon-wrap {
    color: rgba(255,255,255,0.9);
    margin-bottom: 20px;
  }

  .card-inner h3 {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: #fff;
    margin: 0 0 15px 0;
    letter-spacing: 0.5px;
  }

  .card-inner p {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #a0a0a0;
    margin: 0;
  }

  .num {
    position: absolute;
    bottom: 20px;
    right: 25px;
    font-family: 'Bebas Neue', 'Anton', 'Inter', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5); /* Helps number pop on glass */
  }

  /* SVG Drawing Animation */
  .outline-svg {
    position: absolute;
    top: -10px;
    right: -10px;
    bottom: -10px;
    left: -10px;
    width: calc(100% + 20px);
    height: calc(100% + 20px);
    z-index: 1;
    pointer-events: none; /* Let hovers pass through to the card */
  }

  /* Keyframes for a short running line animation */
  @keyframes drawOutline {
    0% {
      stroke-dashoffset: 100;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }

  .svg-rect {
    fill: none;
    stroke-width: 3;
    /* 20% length line, 80% gap to equal the 100 pathLength */
    stroke-dasharray: 20 80;
    /* Linear animation for a constant running speed */
    animation: drawOutline var(--dur, 6s) linear infinite;
    animation-delay: var(--delay, 0s);
  }

  .svg-rect.glow {
    filter: blur(12px);
    stroke-width: 6;
    opacity: 0.8;
  }

  /* Removed hover speed-up to prevent animation jumping/glitching (stuck effect) */

  @media (max-width: 1200px) {
    .cards-wrapper {
      gap: 30px;
    }
    .info-card {
      width: calc(50% - 30px);
      max-width: 320px;
    }
  }

  @media (max-width: 768px) {
    .info-card {
      width: 100%;
      max-width: 350px;
    }
  }
</style>

<script>
  const initBenefitsAnimation = () => {
    // Make sure GSAP and ScrollTrigger are loaded
    if (typeof (window as any).gsap === 'undefined' || typeof (window as any).ScrollTrigger === 'undefined') {
      setTimeout(initBenefitsAnimation, 100);
      return;
    }

    const gsap = (window as any).gsap;
    const ScrollTrigger = (window as any).ScrollTrigger;
    
    gsap.registerPlugin(ScrollTrigger);

    const heading = document.querySelector('.benefits-infographic .js-animate-title');
    if (heading) {
      const textLines = heading.querySelectorAll('.text-line');
      gsap.set(textLines, { y: "100%", opacity: 0 });

      gsap.to(textLines, {
        scrollTrigger: {
          trigger: heading,
          start: 'top 85%',
        },
        y: "0%",
        opacity: 1,
        duration: 1,
        stagger: 0.15,
        ease: 'power2.out',
      });
    }
  };

  document.addEventListener('DOMContentLoaded', initBenefitsAnimation);
  document.addEventListener('astro:page-load', initBenefitsAnimation);
</script>

<script>
  if (!(window as any).shimmerSweepInit) {
    (window as any).shimmerSweepInit = true;
    
    const initShimmer = () => {
      const textEls = document.querySelectorAll('.shimmer-text');
      if (!textEls.length) return;

      const ease = {
        out:   (t: number) => 1 - (1 - t) ** 3,
        in:    (t: number) => t ** 3,
      };

      function cyc(f: number, offset: number, enter: number, hold: number, exit: number, pause: number) {
        if (f < offset) return 0;
        const total = enter + hold + exit + pause;
        const t = (f - offset) % total;
        if (t < enter)               return ease.out(t / enter);
        if (t < enter + hold)        return 1;
        if (t < enter + hold + exit) return 1 - ease.in((t - enter - hold) / exit);
        return 0;
      }

      function grad(el: HTMLElement, css: string) {
        el.style.background           = css;
        el.style.webkitBackgroundClip = 'text';
        el.style.backgroundClip       = 'text';
        el.style.webkitTextFillColor  = 'transparent';
      }

      let _raf: number;
      function loop(tick: () => void) {
        cancelAnimationFrame(_raf);
        (function frame() { tick(); _raf = requestAnimationFrame(frame); })();
      }

      const allChars: any[] = [];
      textEls.forEach(el => {
        if (el.querySelector('.char')) return;
        
        const baseColor = el.getAttribute('data-base') || '#ffffff';
        const sweepColor = el.getAttribute('data-sweep') || '#08c098';

        const text = el.textContent || '';
        el.innerHTML = '';
        const chars: any[] = [];
        
        text.split('').forEach(ch => {
          const s = document.createElement('span');
          s.className = 'char';
          s.textContent = ch;
          el.appendChild(s);
          chars.push({ el: s, base: baseColor, sweep: sweepColor });
        });
        
        allChars.push(chars);
      });

      const STAGGER = 8, ENTER = 84, HOLD = 20, EXIT = 58, PAUSE = 36;
      let f = 0;
      
      loop(() => {
        f++;
        allChars.forEach(chars => {
          chars.forEach((charObj, i) => {
            const p   = cyc(f, i * STAGGER, ENTER, HOLD, EXIT, PAUSE);
            const mid = (p * 130 - 15).toFixed(1);
            grad(charObj.el, `linear-gradient(90deg,
              ${charObj.base} 0%,
              ${charObj.base} ${(+mid - 18).toFixed(1)}%,
              ${charObj.sweep} ${mid}%,
              ${charObj.base} ${(+mid + 18).toFixed(1)}%,
              ${charObj.base} 100%)`);
          });
        });
      });
    };

    document.addEventListener('DOMContentLoaded', initShimmer);
    document.addEventListener('astro:page-load', initShimmer);
    if (document.readyState === 'interactive' || document.readyState === 'complete') {
      initShimmer();
    }
  }
</script>
