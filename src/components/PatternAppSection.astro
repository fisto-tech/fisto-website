<section id="pattern-app" class="section section--pattern-app">
  <div class="pattern-app__container">
    <div
      class="pattern-app__visual"
      data-aos="fade-right"
      data-aos-duration="1200"
      data-aos-delay="200"
    >
      <img
        src="/images/pattern-app/pattern-image.webp"
        alt="Pattern App Interface"
        class="pattern-app__image"
      />
    </div>

    <div class="pattern-app__content">
      <h2
        class="pattern-app__title"
        data-aos="fade-down"
        data-aos-duration="800"
      >
        <span class="highlight">3D MOCKUP</span> APP
      </h2>
      <hr
        class="pattern-app__divider"
        data-aos="zoom-in"
        data-aos-delay="100"
      />
      <h3
        class="pattern-app__subtitle"
        data-aos="fade-left"
        data-aos-delay="200"
        data-aos-duration="1000"
      >
        Customizable <span class="highlight">3D Mockup</span> App
      </h3>
      <p
        class="pattern-app__desc"
        data-aos="fade-left"
        data-aos-delay="300"
        data-aos-duration="1000"
      >
        Create, personalize, and preview packaging in real time with powerful
        branding and design tools.
      </p>

      <ul class="pattern-app__features">
        <li data-aos="fade-up" data-aos-delay="0">
