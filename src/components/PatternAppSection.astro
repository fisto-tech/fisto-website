<style>
  .section--pattern-app {
    min-height: unset;
    background: url("/images/pattern-app/pattern-app-bg.webp") center
      center/cover no-repeat;
    background-color: #071518;
    color: #ffffff;
    padding: 2.9rem clamp(1rem, 5vw, 4rem);
    flex-direction: column;
    overflow: hidden;
  }

  .pattern-app__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(1.4rem, 3.2vw, 2.5rem);
    max-width: 95%;
    width: 100%;
    margin: 0 auto;
  }

  .pattern-app__visual {
    flex: 0 1 55%;
    display: flex;
    justify-content: center;
  }

  .pattern-app__image {
    max-width: 80%;
    width: 80%;
    height: auto;
    object-fit: contain;
    transform: none;
  }

  .pattern-app__content {
    flex: 0 0 50%;
    display: flex;
    flex-direction: column;
  }

  .pattern-app__title {
    font-size: clamp(2.35rem, 3.3vw, 3rem);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    line-height: 1.1;
    white-space: nowrap;
  }

  .pattern-app__divider {
    width: 100px;
    height: 4px;
    background: #22d3ee;
    border: none;
    margin-bottom: 1.35rem;
    border-radius: 2px;
  }

  .pattern-app__subtitle {
    font-size: clamp(1.35rem, 2.6vw, 2.2rem);
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 1rem;
    white-space: nowrap;
  }

  .pattern-app__subtitle .highlight {
    font-weight: 800;
  }

  .pattern-app__desc {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(255, 255, 255, 0.86);
    line-height: 1.6;
    margin-bottom: 1.35rem;
    font-weight: 400;
  }

  .pattern-app__features {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pattern-app__features li {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .pattern-app__icon {
    width: 30px;
    height: 30px;
    color: #22d3ee;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .pattern-app__icon svg {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    display: block;
  }

  @media screen and (max-width: 991px) {
    .pattern-app__container {
      flex-direction: column;
      text-align: center;
      gap: 3rem;
    }

    .pattern-app__content {
      align-items: center;
    }

    .pattern-app__title,
    .pattern-app__subtitle,
    .pattern-app__desc {
      text-align: center;
      white-space: normal;
    }

    .pattern-app__divider {
      margin: 1.5rem auto;
    }

    .pattern-app__features {
      width: fit-content;
      max-width: min(92%, 520px);
      margin-left: auto;
      margin-right: auto;
      align-items: flex-start;
    }

    .pattern-app__features li {
      text-align: left;
      justify-content: flex-start;
    }

    .pattern-app__visual {
      justify-content: center;
    }
  }
</style>
