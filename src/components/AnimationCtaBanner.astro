---

<section class="animation-cta-section">
  <div class="cta-container">
    <div class="cta-content">
      <h2>Ready to Bring Your Vision to Life?</h2>
      <p>Let's collaborate to create stunning 2D and 3D animations that captivate your audience, simplify complex ideas, and elevate your brand to the next level.</p>
      
      <div class="cta-actions">
        <a href="#" class="primary-btn">
          Start Your Project
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a href="#" class="secondary-btn">View Portfolio</a>
      </div>
    </div>
    
    <!-- Decorative floating elements for the animation theme -->
    <div class="floating-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>
  </div>
</section>

<style>
  .animation-cta-section {
    padding: 100px 20px;
    background: #050505;
    display: flex;
    justify-content: center;
  }

  .cta-container {
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    width: 100%;
    max-width: 1200px;
    border-radius: 40px;
    padding: 80px 40px;
    position: relative;
    overflow: hidden;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.05);
  }

  .cta-content {
    position: relative;
    z-index: 10;
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-family: 'Bebas Neue', 'Anton', sans-serif;
    color: #fff;
    letter-spacing: 2px;
    margin: 0 0 20px 0;
    line-height: 1.1;
  }

  .cta-content p {
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    font-family: 'Inter', sans-serif;
    color: #cbd5e1;
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .primary-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 18px 40px;
    background: #22d3ee;
    color: #000;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    border-radius: 30px;
    transition: all 0.3s ease;
  }

  .primary-btn:hover {
    background: #fff;
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(34, 211, 238, 0.4);
  }

  .secondary-btn {
    display: inline-flex;
    align-items: center;
    padding: 18px 40px;
    background: transparent;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    border-radius: 30px;
    border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.3s ease;
  }

  .secondary-btn:hover {
    background: rgba(255,255,255,0.1);
    border-color: #fff;
  }

  /* Floating 3D-like Shapes */
  .floating-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .shape {
    position: absolute;
    background: linear-gradient(45deg, #22d3ee, #818cf8);
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.4;
    animation: float 10s infinite ease-in-out alternate;
  }

  .shape-1 {
    width: 300px;
    height: 300px;
    top: -100px;
    left: -50px;
    background: linear-gradient(45deg, #c084fc, #818cf8);
  }

  .shape-2 {
    width: 400px;
    height: 400px;
    bottom: -150px;
    right: -100px;
    background: linear-gradient(45deg, #2dd4bf, #22d3ee);
    animation-delay: -5s;
  }

  .shape-3 {
    width: 200px;
    height: 200px;
    top: 50%;
    left: 60%;
    background: linear-gradient(45deg, #f472b6, #c084fc);
    animation-delay: -2s;
  }

  @keyframes float {
    0% { transform: translate(0, 0) rotate(0deg); }
    100% { transform: translate(30px, -50px) rotate(20deg); }
  }
</style>
