---
// src/components/IdcCtaBanner.astro
const { 
  image = "/images/first-time/lap-image.webp" 
} = Astro.props;
---

<section class="banner-section">
  <div class="banner-wrapper">
    <!-- Right side Background Image -->
    <img class="bg-image" src={image} alt="Interactive Digital Catalogue" />

    <!-- Layered S-Curve Overlay for the Split Effect -->
    <svg class="wave-overlay" viewBox="0 0 100 100" preserveAspectRatio="none">
      <!-- Dark Green Wave (Bottom layer) -->
      <path d="M0,0 L58.5,0 C47,40 66,60 48.5,100 L0,100 Z" fill="#0d2618" />
      <!-- Mid Green Wave (Middle layer) -->
      <path d="M0,0 L58.2,0 C45.5,40 64,60 48.2,100 L0,100 Z" fill="#1a4f3b" />
      <!-- Solid White Area (Top layer) -->
      <path d="M0,0 L58,0 C44,40 62,60 48,100 L0,100 Z" fill="#ffffff" />
    </svg>

    <!-- Left side Content on the White Area -->
    <div class="content-left">
      <!-- Main Title -->
      <h2 class="title">
        <span class="text-dark">TRANSFORM YOUR</span><br/>
        <span class="text-dark">SALES EXPERIENCE</span>
      </h2>
      
      <!-- Description -->
      <p class="desc">
        Upgrade from traditional printed materials to immersive Interactive Digital Catalogues. Attract more visitors, engage customers, and generate quality leads seamlessly.
      </p>
      
      <!-- Bottom Icons Row -->
      <div class="features-row">
        <div class="feature">
          <div class="icon-circle">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"></path><path d="M12 8v8"></path><path d="M8 12h8"></path></svg>
          </div>
          <span>Increase<br/>Sales</span>
        </div>
        <div class="feature">
          <div class="icon-circle">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
          </div>
          <span>Save<br/>Time</span>
        </div>
        <div class="feature">
          <div class="icon-circle">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <span>Engage<br/>Leads</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@500;700;900&family=Montserrat:wght@400;500;600;700&display=swap');

  .banner-section {
    padding: 30px 20px;
    display: flex;
    justify-content: center;
    background-color: #f1f5f9;
    width: 100%;
  }

  .banner-wrapper {
    position: relative;
    width: 100%;
    max-width: 1200px;
    height: 300px; /* Reduced height */
    background-color: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
    font-family: 'Montserrat', sans-serif;
  }

  .bg-image {
    position: absolute;
    top: 50%;
    right: 0;
    width: 50%;
    height: 90%;
    object-fit: contain;
    z-index: 1;
    transform: translateY(-50%) translateX(-5%);
  }

  .wave-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 94%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .content-left {
    position: absolute;
    top: 0;
    left: 0;
    width: 55%; /* Covers the white area */
    height: 100%;
    z-index: 3;
    padding: 30px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .title {
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    line-height: 1.1;
    font-weight: 900;
    font-family: 'Oswald', sans-serif;
    margin: 0 0 12px 0;
    letter-spacing: 0px;
    text-transform: uppercase;
  }

  .text-dark {
    color: #1a4f3b; /* Very dark rich green tone matching IDC */
  }

  .desc {
    font-size: 0.85rem;
    color: #64748b;
    line-height: 1.4;
    margin: 0 0 15px 0;
    max-width: 90%;
    font-weight: 500;
  }

  .features-row {
    display: flex;
    gap: 25px;
  }

  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 6px;
  }

  .icon-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: #1a4f3b; /* Dark green matching the reference icons */
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }

  .feature span {
    font-size: 0.65rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.3;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .banner-wrapper {
      height: auto;
      min-height: 600px;
      display: flex;
      flex-direction: column;
    }
    .wave-overlay {
      display: none; /* Hide the complex wave on mobile */
    }
    .bg-image {
      position: relative;
      width: 100%;
      height: 250px;
      order: 1; /* Image on top */
      transform: none;
      top: 0;
    }
    .content-left {
      position: relative;
      width: 100%;
      height: auto;
      padding: 40px 20px;
      order: 2; /* Content below image */
      align-items: center;
      text-align: center;
    }
    .desc {
      max-width: 100%;
    }
    .features-row {
      justify-content: center;
      flex-wrap: wrap;
    }
  }
</style>
