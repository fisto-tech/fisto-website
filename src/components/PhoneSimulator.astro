---
// PhoneSimulator.astro
// Shell for the 3 mobile app simulations
import AppBusiness from './AppBusiness.astro';
import AppPattern from './AppPattern.astro';
import AppEvent from './AppEvent.astro';
---

<div class="phone-frame" id="mainPhoneFrame">
  <div class="phone-notch"></div>
  
  <div class="app-layer active" id="layer-app">
    <AppBusiness />
  </div>

  <div class="app-layer" id="layer-pattern">
    <AppPattern />
  </div>

  <div class="app-layer" id="layer-event">
    <AppEvent />
  </div>

</div>

<style>
/* PHONE HARDWARE SHELL */
.phone-frame {
  width: 340px;
  height: 700px;
  background-color: #0b1120;
  border-radius: 44px;
  border: 10px solid #1e293b;
  position: relative;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), inset 0 0 0 2px #334155;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  margin: 0 auto;
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.phone-notch {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 140px;
  height: 28px;
  background-color: #1e293b;
  border-bottom-left-radius: 20px;
  border-bottom-right-radius: 20px;
  z-index: 100;
}

/* APP LAYERS */
.app-layer {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.5s ease;
}

.app-layer.active {
  opacity: 1;
  pointer-events: auto;
  z-index: 50;
}
</style>

<script>
// We listen for a custom event from the page sidebar to swap the layers
document.addEventListener('swapPhoneTheme', (e: any) => {
  const theme = e.detail.theme; // 'app', 'pattern', 'event'
  
  const layers = document.querySelectorAll('.app-layer');
  layers.forEach(layer => {
    if(layer.id === `layer-${theme}`) {
      layer.classList.add('active');
    } else {
      layer.classList.remove('active');
    }
  });
});
</script>
