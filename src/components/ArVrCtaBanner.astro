---
const { 
  image = "/images/services/AR-VR/AR-world-img.webp" 
} = Astro.props;
---

<section class="cta-banner-section">
  <div class="cta-banner-wrapper">
    
    <!-- Right side Image Background -->
    <div class="cta-image-bg" style={`background-image: url('${image}');`}></div>

    <!-- The S-Curve White Shape (SVG) -->
    <div class="cta-shape-container">
     <svg class="cta-shape" viewBox="0 0 1000 300" preserveAspectRatio="none">
        <defs>
          <filter id="blob-shadow" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="15" dy="0" stdDeviation="20" flood-color="#000" flood-opacity="0.6"/>
          </filter>
        </defs>
    <path
        fill="#f4f5f7"
        filter="url(#blob-shadow)"
        d="
        M0,0
        H520
        C600,0 620,18 620,40
        C620,60 610,78 585,92
        C555,108 555,130 590,145
        C640,165 650,205 610,235
        C575,262 510,280 450,300
        H0
        Z"
    />
</svg>
    </div>

    <!-- Left Side Content -->
    <div class="cta-content">
      <div class="cta-header">
        <!-- Logo / Icon mark matching the top right of the white area -->
        <div class="cta-logo-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8 text-gold">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" />
          </svg>
        </div>
      </div>
      
      <h2 class="cta-title">
        <div class="cta-line-wrap"><span class="text-dark cta-text-anim">IMMERSIVE</span></div>
        <div class="cta-line-wrap"><span class="text-dark cta-text-anim">TECH FOR</span><br/></div>
        <div class="cta-line-wrap"><span class="text-gold cta-text-anim">BUSINESS</span></div>
      </h2>
      
      <div class="cta-line-wrap">
        <p class="cta-desc cta-text-anim">
          Cutting-edge Virtual and Augmented Reality solutions tailored to redefine user engagement and elevate your brand globally.
        </p>
      </div>
      
      <div class="cta-footer">
        
        <a href="#" class="cta-btn">
          <span>GET A QUOTE</span>
        </a>
      </div>
    </div>

    <!-- Overlapping Circle (Golden/Sand colored) -->
    <div class="cta-circle-badge">
      <div class="circle-content">
        <span class="circle-sub">FULLY</span>
        <span class="circle-title">CUSTOMIZED</span>
        <span class="circle-sub">SOLUTIONS</span>
      </div>
    </div>

    <!-- Overlapping Pill (Bottom Right) -->
    <div class="cta-pill-badge">
      AR • VR • MR • METAVERSE
    </div>

  </div>
</section>

<style>
  .cta-banner-section {
    padding: 40px 20px;
    width: 100%;
    display: flex;
    justify-content: center;
    background-color: #ffffff; 
  }

  .cta-banner-wrapper {
    position: relative;
    width: 100%;
    max-width: 1200px;
    height: 300px; /* Reduced height */
    background-color: #111;
    border-radius: 12px;
    /* box-shadow: 0 20px 40px rgba(0,0,0,0.6); */
    overflow: hidden;
    display: flex;
  }

  .cta-image-bg {
    position: absolute;
    top: 0;
    right: 0;
    width: 60%;
    height: 100%;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    z-index: 1;
  }

  .cta-shape-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .cta-shape {
    width: 100%;
    height: 100%;
  }

  .cta-content {
    position: relative;
    width: 52%; /* Increased to utilize the wider SVG path space */
    height: 100%;
    z-index: 3;
    padding: 30px 40px; 
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .cta-header {
    display: flex;
    justify-content: flex-end;
    width: 75%; /* Aligns logo towards the curve */
  }

  .cta-logo-mark {
    width: 32px; 
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #c99866; 
  }

  .cta-title {
    font-size: clamp(1.8rem, 2.5vw, 2.5rem); 
    font-weight: 900;
    line-height: 0.95;
    margin: 0;
    letter-spacing: -0.02em;
    font-family: var(--font-primary, system-ui);
  }

  .text-dark {
    color: #2d3748;
  }

  .text-gold {
    color: #c99866;
  }

  .cta-desc {
    color: #4a5568;
    font-size: 0.85rem; 
    line-height: 1.4;
    max-width: 90%; /* Let it use more of the narrowed container */
    margin-top: 10px;
    margin-bottom: 15px;
    font-weight: 500;
  }

  .cta-footer {
    display: flex;
    align-items: center;
    gap: 25px;
  }

  .cta-contact {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .icon-circle {
    width: 32px; 
    height: 32px;
    background-color: #c99866;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-circle svg {
    width: 16px;
    height: 16px;
    color: white;
  }

  .contact-text {
    display: flex;
    flex-direction: column;
  }

  .call-us {
    font-size: 0.7rem;
    color: #718096;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .phone-num {
    font-size: 0.9rem; 
    font-weight: 800;
    color: #2d3748;
  }

  .cta-btn {
    background-color: #c99866;
    color: white;
    padding: 10px 22px; 
    border-radius: 30px;
    text-decoration: none;
    font-size: 0.75rem; 
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cta-btn:hover {
    background-color: #b08253;
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(201, 152, 102, 0.4);
  }

  /* Overlapping Badges */
  .cta-circle-badge {
    position: absolute;
    top: 65%; /* Adjusted for the new bottom bump height */
    left: 62%; /* Perfectly centered over the 650px outward bulge */
    transform: translate(-50%, -50%);
    width: 125px; 
    height: 125px;
    background-color: #c99866;
    border-radius: 50%;
    border: 8px solid #f4f5f7; 
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
  }

  .circle-content {
    display: flex;
    flex-direction: column;
    color: white;
  }

  .circle-sub {
    font-size: 0.6rem; /* Smaller */
    font-weight: 700;
    letter-spacing: 0.05em;
    opacity: 0.9;
  }

  .circle-title {
    font-size: 0.9rem; /* Smaller */
    font-weight: 900;
    margin: 3px 0;
    line-height: 1;
  }

  .cta-pill-badge {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background-color: #c99866;
    color: white;
    padding: 8px 20px; /* Reduced */
    border-radius: 50px;
    font-size: 0.75rem; /* Smaller */
    font-weight: 800;
    letter-spacing: 0.05em;
    border: 4px solid #f4f5f7; 
    z-index: 4;
    box-shadow: 0 10px 20px rgba(0,0,0,0.25);
  }

  /* Responsive Adjustments */
  @media (max-width: 992px) {
    .cta-banner-wrapper {
      height: auto;
      min-height: 400px;
      flex-direction: column;
    }

    .cta-shape-container {
      display: none; 
    }

    .cta-image-bg {
      position: relative;
      width: 100%;
      height: 200px;
    }

    .cta-content {
      width: 100%;
      height: auto;
      background-color: #f4f5f7;
      padding: 30px 20px;
    }

    .cta-circle-badge {
      top: 200px;
      left: 50%;
    }
    
    .cta-header {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .cta-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 15px;
    }
    
    .cta-circle-badge {
      transform: translate(-50%, -50%) scale(0.8);
    }
    
    .cta-pill-badge {
      bottom: auto;
      top: 15px;
      right: 10px;
      font-size: 0.65rem;
      padding: 6px 12px;
    }
  }
</style>
