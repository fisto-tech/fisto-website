---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedCounter from '../components/AnimatedCounter.astro';
import StickyCards from '../components/StickyCards.astro';
import AnimationBenefits from '../components/AnimationBenefits.astro';
import ClientMarquee from '../components/ClientMarquee.astro';
import AnimationCtaBanner from '../components/AnimationCtaBanner.astro';
---

<BaseLayout
  title="Best Animation Company in Coimbatore | Leading 3D Animation Studio in India"
  description="Looking for the best 3D animation company in Coimbatore, India? We provide affordable 2D & 3D animation services with creative visual storytelling solutions."
  keywords="3d design, animation videos, video animation, 2d animation studio, 3d animation services, cgi animation,3d product animation,animation serviceS, 3d explainer video,2d animation companies, 3d visualization,video animation services, product animation,3d animation agency,2d explainer video,make animation, 3d design services,explainer video services,studio 3d,animation production, 2d animation video, product animation videos3d product animation services,2d/3d animation company in chennai, 3d animation company in coimbatore, animation studio in tamilnadu, explainer video company chennai, product animation services tamilnadu, architectural 3d visualization chennai, motion graphics company tamilnadu, character animation studio chennai, corporate video animation services tamilnadu, best animation company in tamilnadu,  2d animation, 3d animation, 2d and 3d animation, 2d animation services, 3d animation services, 2d animation company, 3d animation company, 2d animation studio, 3d animation studio, animated video production, motion graphics, explainer video animation, character animation, product animation, architectural animation, 3d product visualization,2D/3D Animation Services in Coimbatore, Catalogue Services in India, 3D Virtual Tour Services in Coimbatore, Website Services in Coimbatore, Customized App Development Company in Coimbatore, Top AR VR companies India 2D, AR/VR development, 3D animation services Coimbatore, Best VR AR companies India animation services Coimbatore, AR VR solutions India 2D 3D animation Coimbatore providers, Leading AR/VR firms India animation rendering Coimbatore, India virtual reality companies 3D animation services Coimbatore,3D Animation Company India, Product 3D Animation Services, Industrial Animation Services, Explainer Video Animation Company, Motion Graphics Animation Studio, Architectural 3D Walkthrough Services, CGI Animation Studio India, Corporate Animation Production Services, Marketing Animation Solutions, 2D/3D Animation Services in Coimbatore, 3D Animation in India, Branding Animation, Top 3D Animation Services, Product Animation, 3D Animation Studios Coimbatore, Professional Animation Services India, Creative Product Animation India, Best 2D Animation Company Coimbatore, Industrial 3D Animation India, Motion Graphics Services Coimbatore, Explainer Video Animation India"
  image="/images/about-og.jpg"
  current="2d-3d-animation"
  additionalStyles="/css/2d-3d-animation.css"
>
<section class="animation-hero">
  <!-- Removed 'loop' so it triggers 'ended' event -->
  <video id="heroVideo" class="animation-video" autoplay muted playsinline>
    <source src="/images/services/2D-3D-animation/2D-3D-animation-video-new.mp4" type="video/mp4" />
  </video>
  
  <div id="heroOverlay" class="animation-overlay">
    <div id="heroContent" class="hero-content">
      <div class="title-container" style="overflow: hidden;">
        <h1 id="heroTitle" class="hero-title">Bring your ideas to life</h1>
      </div>
      
      <div id="heroTextScroll" class="hero-text-scroll" style="clip-path: polygon(50% 0, 50% 0, 50% 100%, 50% 100%); overflow: hidden;">
        <div class="hero-subtitle">
          <h1 id="heroTextInner" class="hero-text-inner">
            3D Modeling
          </h1>
        </div>
      </div>

      <h2 class="hero-desc">
        Creative. Engaging. Dynamic. We deliver top-tier 2D and 3D visuals to elevate your brand.
      </h2>

      <div class="hero-button mt-4">
        <a href="#" class="primary-btn">Explore Animation</a>
      </div>
    </div>
  </div>
</section>

<AnimatedCounter />

<StickyCards />

<AnimationBenefits />

<ClientMarquee />

<AnimationCtaBanner />

<style>
  .animation-hero {
    position: relative;
    width: 100%;
    height: calc(100vh - 80px);
    overflow: hidden;
    background: #000;
  }
  
  .animation-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .animation-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .animation-overlay.video-ended {
    opacity: 1;
  }

  .hero-content {
    color: #fff;
    padding: 0 20px;
    opacity: 0; /* Revealed by GSAP */
    transform: translateY(30px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .title-container {
    padding-bottom: 10px; /* Leave space for descenders to avoid clipping */
  }

  .hero-title {
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 800;
    margin: 0;
    font-family: 'Bebas Neue', 'Anton', sans-serif;
    letter-spacing: 2px;
    line-height: 1.1;
  }

  .hero-text-scroll {
    margin-bottom: 25px;
  }

  .hero-text-inner {
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 700;
    color: #22d3ee;
    font-family: 'Outfit', sans-serif;
    display: inline-block;
    margin: 0;
    line-height: 1.1;
  }

  .hero-desc {
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    font-family: 'Inter', sans-serif;
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto 30px auto;
    line-height: 1.6;
    font-weight: 400;
  }

  .primary-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 35px;
    background: transparent;
    color: #fff;
    font-family: "Inter", sans-serif;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid #22d3ee;
    border-radius: 30px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .primary-btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background: #22d3ee;
    z-index: -1;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .primary-btn:hover {
    color: #000;
    box-shadow: 0 10px 20px rgba(34, 211, 238, 0.2);
  }

  .primary-btn:hover::before {
    width: 100%;
  }
</style>

<Fragment slot="bodyEnd">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const video = document.getElementById("heroVideo");
      const overlay = document.getElementById("heroOverlay");
      const title = document.getElementById("heroTitle");
      const content = document.getElementById("heroContent");
      const textScroll = document.getElementById("heroTextScroll");
      const textInner = document.getElementById("heroTextInner");
      
      const words = [
        "3D Modeling",
        "2D Animation",
        "Motion Graphics",
        "Visual Effects",
        "Character Design"
      ];
      let currentWordIndex = 0;

      // Manual character split (fallback for SplitText)
      const chars = title.innerText.split("").map(char => {
        if (char === " ") {
          return `<span class="char" style="display:inline-block; white-space:pre;"> </span>`;
        }
        return `<span class="char" style="display:inline-block">${char}</span>`;
      });
      title.innerHTML = chars.join("");
      const charElements = title.querySelectorAll(".char");

      let videoEnded = false;

      const startAnimations = () => {
        if (videoEnded) return;
        videoEnded = true;

        // 1. Show overlay background
        overlay.classList.add("video-ended");

        // 2. Play intro timeline
        const tl = gsap.timeline();
        
        tl.to(content, {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: "power1.inOut"
        })
        .from(charElements, {
          yPercent: 150, // Reduced from 200 so it doesn't clip excessively
          stagger: 0.03,
          ease: "power2.out",
          duration: 0.8
        }, "-=0.2")
        .to(textScroll, {
          duration: 1,
          clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
          ease: "circ.out"
        }, "-=0.6");

        // 3. Start word cycle loop
        setInterval(() => {
          gsap.to(textInner, {
            yPercent: -120,
            opacity: 0,
            duration: 0.4,
            ease: "power2.in",
            onComplete: () => {
              currentWordIndex = (currentWordIndex + 1) % words.length;
              textInner.innerText = words[currentWordIndex];
              
              gsap.fromTo(textInner, 
                { yPercent: 120, opacity: 0 },
                { yPercent: 0, opacity: 1, duration: 0.6, ease: "power2.out" }
              );
            }
          });
        }, 3500);
      };

      if (video) {
        // If it's already ended (cached)
        if (video.ended) {
          startAnimations();
        } else {
          video.addEventListener("ended", startAnimations);
        }
      }
    });
  </script>
</Fragment>
</BaseLayout>
