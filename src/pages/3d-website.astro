---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryModal from '../components/GalleryModal.astro';
import Web3dBenefits from '../components/Web3dBenefits.astro';
import Web3dCtaBanner from '../components/Web3dCtaBanner.astro';
import ClientMarquee from '../components/ClientMarquee.astro';
import '../styles/service1.css';

// Placeholder data for the gallery modal
const galleryItems = [
  { title: "Manufacturing 3D Hub", image: "https://placehold.co/600x400/1a1a1a/ffffff?text=Manufacturing", video: "https://www.w3schools.com/html/mov_bbb.mp4" },
  { title: "Healthcare Virtual Tour", image: "https://placehold.co/600x400/1a1a1a/ffffff?text=Healthcare", video: "https://www.w3schools.com/html/mov_bbb.mp4" },
  { title: "Real Estate Walkthrough", image: "https://placehold.co/600x400/1a1a1a/ffffff?text=Real+Estate", video: "https://www.w3schools.com/html/mov_bbb.mp4" },
  { title: "Retail 3D Store", image: "https://placehold.co/600x400/1a1a1a/ffffff?text=Retail", video: "https://www.w3schools.com/html/mov_bbb.mp4" },
  { title: "Education Metaverse", image: "https://placehold.co/600x400/1a1a1a/ffffff?text=Education", video: "https://www.w3schools.com/html/mov_bbb.mp4" }
];

const tabs = [
  { id: "beverage", label: "Beverage", url: "https://beverage-1.vercel.app/" },
  { id: "container", label: "Container", url: "https://cafe-1-khaki.vercel.app/" },
  { id: "food", label: "Food", url: "https://zippy-rolypoly-da7b33.netlify.app/" }
];
---

<BaseLayout
  title="Leading 3D Website Development Company in Coimbatore, India"
  description="Fisto Tech Private Limited, a leading web design company in Coimbatore, India, builds responsive and creative websites tailored to your brand vision."
  image="/images/about-og.jpg"
  current="3d-website"
  additionalStyles="/css/services.css"
>

  <!-- Hero Section -->
  <section class="hero-3d-wild" id="wildHeroContainer">
    <div class="wild-hero-content">
      <div class="wild-text-wrapper">
        <div class="wild-text left-text" id="wildTextLeft">3D WEB</div>
        <div class="wild-text right-text" id="wildTextRight">&nbsp;SITE</div>
      </div>
      <div class="wild-video-container" id="wildVideoContainer">
        <video src="/videos/interactive-3d-website-demos.mp4" autoplay loop muted playsinline class="wild-video"></video>
      </div>
    </div>
  </section>

  <!-- Interactive Demo Section -->
  <section class="demo-section">
    
    <!-- Tabs Header -->
    <div class="demo-tabs__header">
      <div class="demo-tabs__list" role="tablist">
        {tabs.map((tab, idx) => (
          <button 
            class={`demo-tab__btn ${idx === 0 ? 'active' : ''}`} 
            role="tab" 
            data-target={tab.id}
            data-url={tab.url}
          >
            {tab.label}
          </button>
        ))}
      </div>
      
      <button class="demo-tabs__view-more" onclick="window.openGalleryModal()">
        View More Demos
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </button>
    </div>

    <!-- Animated Reveal Container -->
    <div class="demo-viewer-wrapper">
      <div class="demo-viewer__loader" id="demoLoader">
        <div class="spinner"></div>
        <p>Loading 3D Experience...</p>
      </div>
      
      <div class="demo-viewer" id="demoViewer">
        <!-- The iframe source will be swapped via Javascript -->
        <iframe 
          id="demoIframe"
          src={tabs[0].url} 
          title="3D Website Demo" 
          frameborder="0" 
          allow="autoplay; fullscreen; vr" 
          class="demo-iframe"
        ></iframe>
      </div>
    </div>

  </section>

  <!-- Benefits Section -->
  <Web3dBenefits />

  <!-- Gallery Popup Modal -->
  <GalleryModal items={galleryItems} />

  <!-- Client Section -->
  <ClientMarquee />

  <!-- Pre-Footer CTA -->
  <Web3dCtaBanner />

</BaseLayout>

<style>
/* --- Split Text Hero Section --- */
.hero-3d-wild {
  height: 100vh;
  width: 100%;
  background: linear-gradient(180deg, #ffffff 0%, #e0e5ec 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.wild-hero-content {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 100%;
  height: 100%;
}

.wild-text-wrapper {
  position: absolute;
  width: 100%;
  display: flex;
  justify-content: center;
  z-index: 10;
  top: 50%;
  transform: translateY(-50%);
}

.wild-text {
  font-size: clamp(4rem, 10vw, 12rem);
  font-family: 'Inter', sans-serif;
  font-weight: 900;
  color: #1a1a1a;
  letter-spacing: -0.02em;
  line-height: 1;
  white-space: pre;
  position: relative;
}

.left-text {
  transform: translateX(0);
}

.right-text {
  transform: translateX(0);
}

.wild-video-container {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 0px; /* Starts hidden */
  height: clamp(250px, 50vh, 600px);
  border-radius: 500px;
  overflow: hidden;
  z-index: 5;
  box-shadow: 0 20px 50px rgba(0,0,0,0.3);
}

.wild-video {
  width: 100vw;
  height: 100%;
  object-fit: cover;
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

/* --- Interactive Demo Section --- */
.demo-section {
  padding: 4rem 5%;
  background-color: #040e1b; /* Matches the dark theme */
  min-height: auto;
}

@media (min-width: 1024px) {
  .demo-section {
    min-height: 100vh;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
}

.demo-tabs__header {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

@media (min-width: 768px) {
  .demo-tabs__header {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    position: relative;
  }
}

.demo-tabs__list {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
}

.demo-tab__btn {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #a3b8bc;
  padding: 0.75rem 1.5rem;
  border-radius: 30px;
  font-size: 1rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
}

.demo-tab__btn:hover {
  background: rgba(255, 255, 255, 0.05);
  color: #fff;
}

.demo-tab__btn.active {
  background: #22d3ee;
  border-color: #22d3ee;
  color: #040e1b;
  box-shadow: 0 8px 20px rgba(34, 211, 238, 0.4);
}

@media (min-width: 768px) {
  .demo-tabs__view-more {
    position: absolute;
    right: 0;
  }
}

.demo-tabs__view-more {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: linear-gradient(90deg, #e8a817, #d97706);
  color: #fff;
  border: none;
  padding: 0.75rem 1.5rem;
  border-radius: 30px;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}

.demo-tabs__view-more:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 20px rgba(232, 168, 23, 0.3);
}

/* --- Animated Reveal Container --- */
.demo-viewer-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  max-height: 800px;
  border-radius: 20px;
  overflow: hidden;
  background-color: #0c2025;
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 30px 60px rgba(0,0,0,0.5);
}

.demo-viewer {
  width: 100%;
  height: 100%;
  opacity: 1;
  transform: scale(1);
  transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.demo-viewer.is-animating {
  opacity: 0;
  transform: scale(0.95);
  pointer-events: none; /* Disable interaction during transition */
}

.demo-iframe {
  width: 100%;
  height: 100%;
  background: #fff; /* Placeholder background */
}

/* Loader */
.demo-viewer__loader {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  color: #22d3ee;
  z-index: 10;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.demo-viewer__loader.active {
  opacity: 1;
}

.spinner {
  width: 50px;
  height: 50px;
  border: 4px solid rgba(34, 211, 238, 0.2);
  border-top-color: #22d3ee;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabs = document.querySelectorAll('.demo-tab__btn');
  const viewer = document.getElementById('demoViewer');
  const iframe = document.getElementById('demoIframe') as HTMLIFrameElement;
  const loader = document.getElementById('demoLoader');

  if (!viewer || !iframe || !tabs.length) return;

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Don't do anything if clicking the already active tab
      if (tab.classList.contains('active')) return;

      // Update Active Tab Styling
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      const targetUrl = tab.getAttribute('data-url');

      // Trigger closing animation
      viewer.classList.add('is-animating');
      if(loader) loader.classList.add('active');

      // Wait for the closing animation to finish (0.5s matches CSS transition)
      setTimeout(() => {
        // Swap iframe source
        if(targetUrl) iframe.src = targetUrl;
        
        // When iframe loads, trigger opening animation
        iframe.onload = () => {
          if(loader) loader.classList.remove('active');
          viewer.classList.remove('is-animating');
        };
        
        // Fallback just in case load event fails or takes too long
        setTimeout(() => {
          if (viewer.classList.contains('is-animating')) {
            if(loader) loader.classList.remove('active');
            viewer.classList.remove('is-animating');
          }
        }, 1500);

      }, 500);
    });
  });

  // Split-text Hero GSAP Animation
  const heroContainer = document.getElementById('wildHeroContainer');
  const leftText = document.getElementById('wildTextLeft');
  const rightText = document.getElementById('wildTextRight');
  const videoContainer = document.getElementById('wildVideoContainer');

  if (heroContainer && leftText && rightText && videoContainer) {
    const gsap = (window as any).gsap;
    const ScrollTrigger = (window as any).ScrollTrigger;
    
    if (gsap && ScrollTrigger) {
      gsap.registerPlugin(ScrollTrigger);
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: heroContainer,
          start: "top top",
          end: "+=150%",
          scrub: 1,
          pin: true
        }
      });

      tl.to(leftText, { x: "-60vw", ease: "power1.inOut" }, 0)
        .to(rightText, { x: "60vw", ease: "power1.inOut" }, 0)
        .to(videoContainer, { width: "100vw", height: "100vh", borderRadius: "0px", ease: "power1.inOut" }, 0);
    }
  }
});
</script>
