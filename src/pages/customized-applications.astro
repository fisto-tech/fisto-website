---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneSimulator from '../components/PhoneSimulator.astro';
import '../styles/service1.css';
---

<BaseLayout
  title="Application Development"
  description="Customized Application Development"
  image="/images/about-og.jpg"
  current="customized-applications"
  additionalStyles="/css/services.css"
>

  <section class="app-dev-section">
    <div class="app-dev-container">
      
      <!-- Left side: Text & App Selector -->
      <div class="app-dev-content">
        <h1 class="app-dev-title">Build <span class="highlight">Powerful</span> Mobile Experiences</h1>
        <p class="app-dev-desc">
          We craft custom mobile applications that feel alive. Interact with our live simulator 
          to experience the smooth transitions, intuitive navigation, and micro-animations we bring to every project.
        </p>

        <h3 class="selector-title">Select App Demo:</h3>
        <div class="app-selector" id="appThemeSelector">
          <button class="selector-btn active" data-theme="app">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Application
          </button>
          <button class="selector-btn" data-theme="pattern">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>
            Pattern App
          </button>
          <button class="selector-btn" data-theme="event">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Event App
          </button>
        </div>
      </div>

      <!-- Right side: Phone Simulator -->
      <div class="app-dev-simulator">
        <PhoneSimulator />
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.app-dev-section {
  padding: 6rem 5%;
  background: linear-gradient(135deg, #071518 0%, #0c2025 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.app-dev-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rem;
  width: 100%;
  max-width: 1200px;
}

@media (min-width: 1024px) {
  .app-dev-container {
    flex-direction: row;
    justify-content: space-between;
  }
}

/* Left Content */
.app-dev-content {
  flex: 1;
  max-width: 500px;
  color: #fff;
}

.app-dev-title {
  font-size: clamp(2.5rem, 4vw, 4rem);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 1.5rem;
}

.highlight {
  color: #22d3ee;
  background: -webkit-linear-gradient(0deg, #22d3ee, #e8a817);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.app-dev-desc {
  font-size: 1.15rem;
  color: #a3b8bc;
  line-height: 1.6;
  margin-bottom: 3rem;
}

/* App Selector */
.selector-title {
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #94a3b8;
  margin-bottom: 1rem;
}

.app-selector {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.selector-btn {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #a3b8bc;
  padding: 1rem 1.5rem;
  border-radius: 12px;
  font-size: 1.1rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 100%;
}

.selector-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  transform: translateX(5px);
}

.selector-btn.active {
  background: linear-gradient(90deg, rgba(34, 211, 238, 0.2), transparent);
  border-left: 4px solid #22d3ee;
  color: #fff;
}

.selector-btn svg {
  transition: transform 0.3s ease;
}

.selector-btn.active svg {
  color: #22d3ee;
  transform: scale(1.1);
}

/* Right Content */
.app-dev-simulator {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const selectors = document.querySelectorAll('.selector-btn');

  selectors.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      selectors.forEach(s => s.classList.remove('active'));
      btn.classList.add('active');

      const theme = btn.getAttribute('data-theme');
      
      // Dispatch event to the PhoneSimulator shell
      document.dispatchEvent(new CustomEvent('swapPhoneTheme', { detail: { theme } }));

      // Add a little subtle shake animation to the phone to indicate change
      const phoneFrame = document.getElementById('mainPhoneFrame');
      if (phoneFrame) {
        phoneFrame.style.transform = 'scale(0.98)';
        setTimeout(() => {
          phoneFrame.style.transform = 'scale(1)';
        }, 150);
      }
    });
  });
});
</script>
