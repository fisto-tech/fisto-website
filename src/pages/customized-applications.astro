---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneSimulator from '../components/PhoneSimulator.astro';
import EventAppSection from '../components/EventAppSection.astro';
import PatternAppSection from '../components/PatternAppSection.astro';
import '../styles/service1.css';
---

<BaseLayout
  title="Application Development"
  description="Customized Application Development"
  image="/images/about-og.jpg"
  current="customized-applications"
  additionalStyles="/css/services.css"
>

  <section class="app-dev-section">
    <div class="app-dev-container">
      
      <!-- Left side: Text & App Selector -->
      <div class="app-dev-content">
        <h1 class="app-dev-title">Build <span class="highlight">Powerful</span> Mobile Experiences</h1>
        <p class="app-dev-desc">
          We craft custom mobile applications that feel alive. Interact with our live simulator 
          to experience the smooth transitions, intuitive navigation, and micro-animations we bring to every project.
        </p>

        <h3 class="selector-title">Select App Demo:</h3>
        <div class="app-selector" id="appThemeSelector">
          <button class="selector-btn active" data-theme="app">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Application
          </button>
          <button class="selector-btn" data-theme="pattern">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16 12-4-4-4 4"/><path d="M12 16V8"/></svg>
            Pattern App
          </button>
          <button class="selector-btn" data-theme="event">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Event App
          </button>
        </div>
      </div>

      <!-- Right side: Phone Simulator -->
      <div class="app-dev-simulator">
        <PhoneSimulator />
      </div>

    </div>
  </section>

  <!-- App Details Sections -->
  <EventAppSection />
  <PatternAppSection />

</BaseLayout>

<style>
.app-dev-section {

  background: linear-gradient(135deg, #071518 0%, #0c2025 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

@media (min-width: 1024px) {
  .app-dev-section {
    height: 100vh;
   /* Small padding for navbar clearance */
  }
}

.app-dev-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rem;
  width: 90%;
  max-width: 1400px;
  margin: 0 auto;
}

@media (min-width: 1024px) {
  .app-dev-container {
    flex-direction: row;
    justify-content: space-between;
  }
}

/* Left Content */
.app-dev-content {
  flex: 0 1 50%;
  max-width: 580px;
  color: #fff;
}

.app-dev-title {
  font-size: clamp(2.2rem, 3.5vw, 3.5rem);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 1rem;
}

.highlight {
  color: #22d3ee;
  background: -webkit-linear-gradient(0deg, #22d3ee, #e8a817);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.app-dev-desc {
  font-size: 1.1rem;
  color: #a3b8bc;
  line-height: 1.6;
  margin-bottom: 2rem;
}

/* App Selector */
.selector-title {
  font-size: 1rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #94a3b8;
  margin-bottom: 1rem;
}

.app-selector {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.selector-btn {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #a3b8bc;
  padding: 0.8rem 1.25rem;
  border-radius: 12px;
  font-size: 1.1rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 100%;
}

.selector-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  transform: translateX(5px);
}

.selector-btn.active {
  background: linear-gradient(90deg, rgba(34, 211, 238, 0.2), transparent);
  border-left: 4px solid #22d3ee;
  color: #fff;
}

.selector-btn svg {
  transition: transform 0.3s ease;
}

.selector-btn.active svg {
  color: #22d3ee;
  transform: scale(1.1);
}

/* Right Content */
.app-dev-simulator {
  flex: 0 1 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  transform: scale(0.95); /* Increased phone frame size globally */
  transform-origin: center center;
}

@media (max-width: 991px) {
  .app-dev-simulator {
    justify-content: center;
    transform: scale(0.85);
    transform-origin: center center;
    margin-top: 2rem;
  }
}
@media (max-height: 850px) and (min-width: 992px) {
  .app-dev-simulator {
    transform: scale(0.85);
  }
}
@media (max-height: 750px) and (min-width: 992px) {
  .app-dev-simulator {
    transform: scale(0.75);
  }
}
@media (max-height: 650px) and (min-width: 992px) {
  .app-dev-simulator {
    transform: scale(0.65);
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const selectors = document.querySelectorAll('.selector-btn');
  const section = document.querySelector('.app-dev-section');
  
  // -- User Interaction State --
  let isUserInteracting = false;
  let inactivityTimer = null;
  const INACTIVITY_DELAY = 5000;

  // -- Autoplay State --
  let autoplayInterval = null;
  let currentAppIndex = 0;
  const THEMES = ['app', 'pattern', 'event'];
  
  // -- Internal App Simulation Timers --
  let simulationTimeouts = [];

  const clearSimulation = () => {
    simulationTimeouts.forEach(t => clearTimeout(t));
    simulationTimeouts = [];
  };

  const simulateClick = (elementSelector) => {
    const el = document.querySelector(elementSelector);
    if (el && !isUserInteracting) {
      el.click();
    }
  };

  const runAppSimulation = (theme) => {
    clearSimulation();
    if (isUserInteracting) return;

    if (theme === 'app') {
      // Simulate Business App
      let t1 = setTimeout(() => simulateClick('.b-nav-item[data-target="analytics"]'), 1500);
      let t2 = setTimeout(() => simulateClick('.b-nav-item[data-target="orders"]'), 3000);
      let t3 = setTimeout(() => simulateClick('.b-nav-item[data-target="profile"]'), 4500);
      let t4 = setTimeout(() => simulateClick('.b-nav-item[data-target="settings"]'), 6000);
      let t5 = setTimeout(() => simulateClick('.b-nav-item[data-target="dashboard"]'), 7500);
      simulationTimeouts.push(t1, t2, t3, t4, t5);
    } else if (theme === 'pattern') {
      // Simulate Pattern App
      // Since Home screen is removed, the viewer is already active!
      let t1 = setTimeout(() => simulateClick('.lid-color-btn:nth-child(3)'), 1500);
      let t2 = setTimeout(() => simulateClick('.tub-color-btn:nth-child(4)'), 3000);
      let t3 = setTimeout(() => document.dispatchEvent(new CustomEvent('patternAppZoomIn')), 4500);
      let t4 = setTimeout(() => document.dispatchEvent(new CustomEvent('patternAppZoomOut')), 6500);
      simulationTimeouts.push(t1, t2, t3, t4);
    } else if (theme === 'event') {
      // Simulate Event App
      let t1 = setTimeout(() => simulateClick('.e-nav-item[data-target="register"]'), 1500);
      let t2 = setTimeout(() => simulateClick('.e-nav-item[data-target="list"]'), 3000);
      let t3 = setTimeout(() => simulateClick('.e-nav-item[data-target="analytics"]'), 4500);
      let t4 = setTimeout(() => simulateClick('.e-nav-item[data-target="profile"]'), 6000);
      let t5 = setTimeout(() => simulateClick('.e-nav-item[data-target="dashboard"]'), 7500);
      simulationTimeouts.push(t1, t2, t3, t4, t5);
    }
  };

  const switchTheme = (theme, fromUser = false) => {
    selectors.forEach(s => s.classList.remove('active'));
    const btn = document.querySelector(`.selector-btn[data-theme="${theme}"]`);
    if(btn) btn.classList.add('active');

    document.dispatchEvent(new CustomEvent('swapPhoneTheme', { detail: { theme } }));

    const phoneFrame = document.getElementById('mainPhoneFrame');
    if (phoneFrame) {
      phoneFrame.style.transform = 'scale(0.98)';
      setTimeout(() => {
        phoneFrame.style.transform = 'scale(1)';
      }, 150);
    }

    if (!fromUser) {
      runAppSimulation(theme);
    }
  };

  const nextApp = () => {
    if (isUserInteracting) return;
    currentAppIndex = (currentAppIndex + 1) % THEMES.length;
    switchTheme(THEMES[currentAppIndex]);
  };

  const startAutoplay = () => {
    isUserInteracting = false;
    clearSimulation();
    clearInterval(autoplayInterval);
    // Switch to current and run simulation
    switchTheme(THEMES[currentAppIndex]);
    // Then cycle every 12 seconds
    autoplayInterval = setInterval(nextApp, 12000);
  };

  const pauseAutoplay = () => {
    isUserInteracting = true;
    clearSimulation();
    clearInterval(autoplayInterval);
    clearTimeout(inactivityTimer);
    
    // Resume after inactivity
    inactivityTimer = setTimeout(() => {
      startAutoplay();
    }, INACTIVITY_DELAY);
  };

  // Add click listeners to selector buttons
  selectors.forEach((btn, index) => {
    btn.addEventListener('click', (e) => {
      if(!e.isTrusted) return; // Ignore simulated clicks for pausing logic
      pauseAutoplay();
      currentAppIndex = index;
      switchTheme(btn.getAttribute('data-theme'), true);
    });
  });

  // Pause if user clicks anywhere in the section
  if (section) {
    section.addEventListener('mousedown', (e) => {
      if(e.isTrusted) pauseAutoplay();
    });
    section.addEventListener('touchstart', (e) => {
      if(e.isTrusted) pauseAutoplay();
    });
  }

  // Start initial autoplay
  setTimeout(startAutoplay, 1000);
});
</script>
