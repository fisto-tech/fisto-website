---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" current="contact">
  <Fragment slot="headContent">

    <link rel="stylesheet" href="/css/contact.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.10/build/css/intlTelInput.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/18.2.0/css/intlTelInput.css" />
    
  </Fragment>

  <section class="contact-us-section">
    <div class="container">
      <div class="left-panel animate-item from-left">
        <img
          src="/images/contact/contact_us_page_image.webp"
          alt="AR/VR Visual"
          class="feature-image"
          loading="eager"
        />
        <h2 id="typingText"></h2>
        <p>
          Discover how AR & VR Solutions can elevate your business — connect
          with our specialists today!
        </p>
      </div>
      <div class="right-panel animate-item from-right">
        <h3>Send us a message</h3>
        <p>
          If you have any work from us or any types of quries related to our
          work, you can send me message from here. It's our pleasure to help
          you.
        </p>
        <form
          id="contactForm"
          autocomplete="off"
          method="post"
          action="https://www.fist-o.com/contact_form/sendMail_SQL.php"
        >
          <div class="form-group">
            <input type="text" id="name" name="name" required placeholder=" " />
            <label for="name">Name *</label>
          </div>
          <div class="form-group">
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder=" "
            />
            <label for="email">Work Email *</label>
          </div>
          <div class="form-group mobile-input">
            <input
              type="tel"
              id="mobileInput"
              name="mobileInput"
              required
              placeholder=" "
              oninput="this.value = this.value.replace(/[^0-9]/g, '');"
              inputmode="numeric"
              pattern="[0-9]*"
              required
            />
            <span class="mobile-label">Mobile *</span>
          </div>
          <div class="form-group">
            <input type="text" id="city" name="city" required placeholder=" " />
            <label for="city">City *</label>
          </div>
          <div class="form-group">
            <input
              type="text"
              id="companyName"
              name="companyName"
              required
              placeholder=" "
            />
            <label for="companyName" class="company-name-label"
              >Company Name *</label
            >
          </div>
          <div class="form-group">
            <input
              type="text"
              id="industry"
              name="industry"
              required
              placeholder=" "
            />
            <label for="industry">Your Industry Type*</label>
          </div>

          <div class="form-group">
            <select
              name="typeOfEnquiry"
              style="padding: 10px 14px;"
              id="enquiryType"
              required
            >
              <option value="" selected disabled>Type of Enquiry</option>
              <option value="AR & VR Development">AR & VR Development</option>
              <option value="E-Commerce 3D Modelling">E-Commerce</option>
              <option value="3D-Interactive Application"
                >3D-Interactive Application</option
              >
              <option value="Customized Android App Development"
                >Customized Android App Development</option
              >
              <option value="2D/3D Animation">2D/3D Animation</option>
              <option value="Web App Development">Web App Development</option>
              <option value="Interactive Digital Catalogue"
                >Interactive Digital Catalogue</option
              >
              <option value="Web Design">Web Design</option>
              <option value="others">Others</option>
            </select>
          </div>

          <div class="form-group">
            <input
              type="text"
              id="others"
              name="others"
              disabled
              required
              placeholder="If others specify here"
              class="inactive-border"
            />
            <label for="others"></label>
          </div>

          <div class="form-group full-row">
            <textarea id="message" name="message" required placeholder=" "
            ></textarea>
            <label for="message">Your Requirement *</label>
          </div>

          <!-- Hidden for result -->
          <input type="hidden" id="fullMobileInput" name="fullMobileInput" />
          <input type="hidden" id="countryNameInput" name="countryNameInput" />
          <input type="hidden" id="countryCodeInput" name="countryCodeInput" />
          <input type="hidden" id="countryISOInput" name="countryISOInput" />

          <button type="submit" class="submit-btn">SUBMIT</button>
          <div id="output" class="full-row"></div>
        </form>
      </div>
    </div>
  </section>

  <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3916.52808624732!2d76.98663437584001!3d10.998948855048187!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ba85953c17a7027%3A0xea6e3a8566c8dbf9!2sFISTO%20TECH%20PRIVATE%20LIMITED!5e0!3m2!1sen!2sin!4v1783690806330!5m2!1sen!2sin" style="border:0; width: 100%; height: 450px; padding: 0 30px; margin-bottom: 1rem;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>

  <Fragment slot="bodyEnd">
      <script src="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.10/build/js/intlTelInput.min.js" is:inline></script>
       

      <script src="/js/contact.js" is:inline></script>
  </Fragment>

</BaseLayout>
