---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About Us "
  description="Learn more about our company, team, and mission."
  image="/images/about-og.jpg"
  current="about"
  additionalStyles="/css/about.css"
>
  <div class="about-header">
    <h1>Where Ideas Take Flight</h1>
    <h2>We turn concepts into fluid, engaging motion.</h2>
  </div>

  <div class="about-container">
    <!-- Image and Text Section -->
    <div class="about-intro">
      <div class="about-image">
        <img
          src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=800&q=80"
          alt="About FIST-O"
        />
      </div>
      <div class="about-text">
        <h2>Who We Are</h2>
        <p>
          At FIST-O, we are passionate innovators dedicated to transforming
          ideas into captivating digital experiences. With expertise in AR/VR,
          3D animation, and cutting-edge application development, we bring your
          vision to life through fluid, engaging motion.
        </p>
        <p>
          Our team combines technical excellence with creative artistry to
          deliver solutions that not only meet but exceed expectations. We
          believe in pushing boundaries and exploring new frontiers in digital
          technology to create immersive experiences that resonate with
          audiences worldwide.
        </p>
        
      </div>
    </div>

    <!-- Vision Mission Goals Section -->
    <div class="vmg-section">
      <div class="vmg-card">
        <div class="vmg-icon">
          <svg viewBox="0 0 24 24">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </div>
        <h3>Vision</h3>
        <p>
          To be the global leader in immersive digital experiences, pioneering
          the future of AR/VR technology and interactive media. We envision a
          world where technology seamlessly blends with creativity to inspire
          and transform lives.
        </p>
      </div>

      <div class="vmg-card">
        <div class="vmg-icon">
          <svg viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
          </svg>
        </div>
        <h3>Mission</h3>
        <p>
          To empower businesses and individuals by delivering innovative,
          high-quality digital solutions that elevate engagement and drive
          growth. We are committed to excellence, creativity, and continuous
          innovation in everything we do.
        </p>
      </div>

      <div class="vmg-card">
        <div class="vmg-icon">
          <svg viewBox="0 0 24 24">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
        </div>
        <h3>Goals</h3>
        <p>
          To expand our technological capabilities, foster long-term client
          partnerships, and consistently deliver projects that set new industry
          standards. We aim to cultivate a culture of innovation and excellence
          within our team.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
