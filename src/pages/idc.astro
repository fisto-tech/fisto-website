---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Interactive Digital Catalogue"
  description="Interactive Digital Catalogue"
  image="/images/about-og.jpg"
  current="about"
   additionalStyles="/css/2d-3d-animation.css"
>


  <section id="services" class="section section--services">
    <div class="catalog-embed" data-aos="zoom-in" data-aos-duration="1000">
      <!-- <h2 class="catalog-embed__title">Interactive Digital Catalogue</h2> -->
      <div class="catalog-embed__container">
        <object data="Fisto_Tech_IDC/index.html" type="text/html" class="catalog-embed__object">
          <p>Your browser does not support embedding this interactive catalogue. Please <a
              href="Fisto_Tech_IDC/index.html" target="_blank" class="highlight">click here to view it directly</a>.
          </p>
        </object>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.section--services {
  /* background: var(--bg);  */
  /* background: linear-gradient(135deg, #0c2025 0%, #071518 100%); */
  background: #45614e;
  min-height: 75vh;
  padding: 0;
}


/* ── Catalog Embed Styles ───────────────────────── */
.catalog-embed {
  width: 100%;
  /* max-width: 1400px; */
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
  /* height: calc(100vh - var(--navbar-height) - 5rem); */
  height: 100%;
  padding-top: 1rem;
  padding-bottom: 1rem;
}

.catalog-embed__title {
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  letter-spacing: -0.01em;
  margin-bottom: 0.5rem;
}

.catalog-embed__container {
  width: 88%;
  flex-grow: 1;
  background: #ffffff;

  overflow: hidden;

}

.catalog-embed__object {
  width: 100%;
  height: 100%;
  min-height: 86.5dvh;
  border: none;
  display: block;
}


@media screen and (max-width: 480px) {
  .catalog-embed__container {
    scale: 1.15;
  }
}

</style>
