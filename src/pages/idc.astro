<style>
  :root {
    --bg: #f2f9fa;
    --bg-dark: #e4f0f2;
    --text-primary: #112025;
    --text-secondary: #1e4550;
    --text-muted: #2a5f6e;
    --accent: #0e7490;
    --accent-light: #22d3ee;
    --highlight: #e8a817;
    --highlight-glow: rgba(232, 168, 23, 0.18);
    --glass-bg: rgba(242, 249, 250, 0.55);
    --glass-border: rgba(255, 255, 255, 0.45);
    --glass-shadow: 0 8px 32px rgba(14, 116, 144, 0.08);
    --navbar-height: 72px;
    --font-family:
      "Poppins", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --transition-smooth: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    --section-title-size: clamp(2.5rem, 5vw, 4rem);
  }
  .section--services {
    /* background: var(--bg);  */
    /* background: linear-gradient(135deg, #0c2025 0%, #071518 100%); */
    background: #45614e;
    min-height: 75vh;
    padding: 0;
  }

  /* ── Catalog Embed Styles ───────────────────────── */
  .catalog-embed {
    width: 100%;
    /* max-width: 1400px; */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    /* height: calc(100vh - var(--navbar-height) - 5rem); */
    height: 100%;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .catalog-embed__title {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }

  .catalog-embed__container {
    width: 88%;
    flex-grow: 1;
    background: #ffffff;

    overflow: hidden;
  }

  .catalog-embed__object {
    width: 100%;
    height: 100%;
    min-height: 86.5dvh;
    border: none;
    display: block;
  }

  @media screen and (max-width: 480px) {
    .catalog-embed__container {
      scale: 1.15;
    }
  }

  .section--first-time {
    min-height: unset;
    background: url("/images/first-time/first-time-bg.webp") center center/cover
      no-repeat;
    background-color: #0c2025;
    color: #ffffff;
    padding: 5rem clamp(1rem, 5vw, 4rem);
    overflow: hidden;
  }
  .section--features {
    /* background: linear-gradient(135deg, #0c2025 0%, #071518 100%); */
    background: url("/images/idc-features-bg.webp") no-repeat center center;
    background-size: cover;
    padding: 2.25rem 0rem;
    min-height: unset;
  }
  /* ── IDC Banner Styles ──────────────────────────── */
  /* ── 1st Time in India Banner ───────────────────── */
  .first-time__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(1rem, 3vw, 2rem);
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
  }
  .first-time__left {
    display: flex;
    align-items: flex-start;
    /* gap: clamp(1rem, 3vw, 2.5rem); */
    gap: 0;
    flex: 0 0 auto;
  }
  .first-time__graphic {
    width: clamp(140px, 17vw, 220px);
    height: auto;
    object-fit: contain;
    flex-shrink: 0;
    filter: drop-shadow(0 15px 25px rgba(0, 0, 0, 0.6));
    margin-top: -0.15rem;
  }
  .first-time__content {
    display: flex;
    flex-direction: column;
  }
  .first-time__badge {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 500;
    color: var(--highlight);
    letter-spacing: 0.05em;
    margin-bottom: 0.2rem;
    text-transform: uppercase;
  }
  .first-time__sup {
    text-transform: lowercase;
    font-size: 0.7em;
    vertical-align: super;
  }
  .first-time__title {
    font-size: clamp(2.25rem, 4.5vw, 4.5rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    margin-bottom: 1.2rem;
    white-space: nowrap;
  }
  .first-time__highlight {
    color: var(--highlight);
  }
  .first-time__divider {
    width: 250px;
    height: 2px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.8) 40%,
      transparent 100%
    );
    border: none;
    margin-bottom: 1.2rem;
  }
  .first-time__desc {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    white-space: nowrap;
  }
  .first-time__right {
    flex: 1 1 auto;
    display: flex;
    justify-content: flex-end;
  }
  .first-time__laptop {
    max-width: 110%;
    width: 110%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 25px 40px rgba(0, 0, 0, 0.7));
    transform: scale(1.05) translateX(3%);
  }
  @media screen and (max-width: 991px) {
    .first-time__laptop {
      max-width: 100%;
      width: 100%;
    }
  }
  /* ── Features Section ───────────────────────────── */
  .features {
    max-width: 1400px;
    width: 100%;
    display: flex;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
  }
  .features--reversed {
    flex-direction: row-reverse;
  }
  .features__visual {
    flex: 1 1 45%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .features__img {
    width: 100%;
    max-width: 100%;
    border-radius: 20px;
    object-fit: cover;
    filter: drop-shadow(0 20px 40px rgba(14, 116, 144, 0.12));
    transition: transform var(--transition-smooth);
  }
  .features__img:hover {
    transform: scale(1.02) translateY(-2px);
  }
  .features__text {
    flex: 1 1 55%;
    max-width: 680px;
  }
  .features__badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .features__title {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 700;
    line-height: 1.25;
    color: #ffffff;
    margin-bottom: 1rem;
  }
  .features__intro {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    color: #a8d0db;
    margin-bottom: 2rem;
  }
  .features__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .features__item {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }
  .features__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(34, 211, 238, 0.1);
    color: var(--accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    margin-top: 0;
  }
  .features__icon svg {
    width: 100%;
    height: 100%;
  }
  .features__item-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 0;
  }
  .features__item-desc {
    font-size: 0.95rem;
    color: #a8d0db;
    line-height: 1.5;
  }
  .features--light .features__title {
    color: #112025;
  }
  .features--light .features__intro {
    color: #2a5f6e;
  }
  .features--light .features__item-title {
    color: #112025;
  }
  .features--light .features__icon {
    background: rgba(14, 116, 144, 0.12);
    color: #0e7490;
  }
  /* ── IDC Features New Layout ───────────────────── */
  .features-wrapper {
    max-width: 1400px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 2rem;
    padding: 0 1rem;
  }
  .features-header {
    font-size: var(--section-title-size);
    font-weight: 800;
    color: var(--highlight);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 1.35rem;
    position: relative;
  }
  .features-header::after {
    content: "";
    display: block;
    width: 120px;
    height: 4px;
    background: var(--highlight);
    margin: 10px auto 0;
    border-radius: 2px;
  }
  .features-layout {
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.95fr);
    align-items: start;
    gap: clamp(1.5rem, 3vw, 3.25rem);
  }
  .features-diagram {
    width: 100%;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    min-width: 0;
  }
  .features-diagram__img {
    width: 93%;
    height: auto;
    object-fit: contain;
  }
  .features-footer {
    text-align: left;
    margin-top: 0;
    min-width: 0;
  }
  .features-footer p {
    font-size: clamp(1.35rem, 2.6vw, 2.2rem);
    color: rgba(255, 255, 255, 0.85);
    font-weight: 400;
  }
  .features-footer p .highlight {
    font-style: italic;
    font-weight: 300;
  }
  .features-highlights {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: flex-start;
    gap: clamp(0.75rem, 1.5vw, 1.5rem);
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    padding: 0;
    max-width: none;
    flex-direction: column;
  }
  .features-highlights__item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  @media screen and (max-width: 480px) {
    .features-highlights__item {
      align-items: flex-start;
    }
  }
  .features-highlights__icon {
    width: clamp(38px, 4vw, 48px);
    height: clamp(38px, 4vw, 48px);
    border-radius: 50%;
    /* background: #2ecc71; */
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .features-highlights__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .features-highlights__label {
    font-size: clamp(0.9rem, 1.35vw, 1.15rem);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.92);
    white-space: normal;
  }
  /* Features: tablet/mobile stacking */
  @media (max-width: 991px) {
    .features-layout {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .features-diagram {
      justify-content: center;
    }
    .features-footer {
      text-align: center;
    }
    .features-highlights {
      justify-content: center;
    }
  }
  /* Subtle alternating tint for visual rhythm */
  .section--hero {
    min-height: 90vh;
    padding: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.301), rgba(255, 255, 255, 0.301)),
      url("/images/hero-background.webp") no-repeat center center;
    background-size: cover;
  }
  .section--about {
    /* background: url('/images/about-solutions-bg.webp') center center/cover no-repeat; */
    background: url("/images/event-app/event-app-bg.webp") center center/cover
      no-repeat;
    background-color: #0c2025;
    padding: 6rem clamp(1.5rem, 4vw, 4rem);
    min-height: unset;
    text-align: center;
    color: #ffffff;
  }
  .about-container {
    max-width: 95%;
    margin: 0 auto;
    text-align: center;
  }
  .about__badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    border: 1.5px solid var(--highlight);
    padding: 0.45rem 1.35rem;
    border-radius: 50px;
    margin-bottom: clamp(1.5rem, 3vw, 2rem);
  }
  .about__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #ffffff;
    margin-bottom: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: 0.01em;
  }
  .about__title .highlight {
    color: var(--highlight);
    -webkit-text-fill-color: var(--highlight);
  }
  .about__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: clamp(1.5rem, 3vw, 2.25rem) auto;
    width: min(480px, 72%);
    max-width: 100%;
  }
  .about__divider::before,
  .about__divider::after {
    content: "";
    flex: 1;
    height: 1px;
  }
  .about__divider::before {
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.9)
    );
  }
  .about__divider::after {
    background: linear-gradient(to left, transparent, rgba(255, 255, 255, 0.9));
  }
  .about__star {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin: 0 0.75rem;
    color: var(--highlight);
    background: none;
    padding: 0;
  }
  .about__tagline {
    font-size: clamp(1.35rem, 2.6vw, 2.2rem);
    color: #ffffff;
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
    font-weight: 600;
    line-height: 1.35;
  }
  .about__tagline .highlight {
    color: var(--highlight);
    -webkit-text-fill-color: var(--highlight);
    font-weight: 600;
  }
  .about__description {
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.65;
    max-width: 100%;
    margin: 0 auto;
    font-weight: 400;
  }
  /* ── Hero ───────────────────────────────────────── */
  .hero {
    width: 100%;
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 0;
    padding: 0;
    min-height: 90vh;
  }
  .hero__text {
    flex: 0 0 35%;
    max-width: 35%;
    padding-left: clamp(0.5rem, 2vw, 2rem);
    padding-top: 2rem;
    padding-bottom: 4rem;
    align-self: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media screen and (min-width: 1800px) {
    .hero {
      align-items: self-start;
    }
    .hero__text {
      margin-left: 4%;
      margin-top: 5.5%;
    }
  }
  .hero__est {
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    text-transform: uppercase;
    font-family: var(--font-family);
    font-weight: 500;
    white-space: nowrap;
    padding-left: 0.5rem;
  }
  .hero__title {
    font-size: clamp(2.8rem, 4vw, 4rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #000000;
    /* Dark color matching image */
    margin-bottom: 0.5rem;
    white-space: nowrap;
  }
  /* Custom Trigger for Continuous Animations */
  [data-aos="trigger-anim"] {
    opacity: 1; /* purely a trigger, no parent transition */
  }
  /* Base style for words */
  .hero__title .word-anim,
  .hero__subtitle .word-anim {
    opacity: 0;
    display: inline-block;
    will-change: opacity, transform, filter;
  }
  /* The infinite reveal animation attached to the AOS trigger class */
  [data-aos="trigger-anim"].aos-animate .word-anim {
