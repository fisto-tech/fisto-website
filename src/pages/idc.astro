---
import BaseLayout from "../layouts/BaseLayout.astro";
import ClientMarquee from "../components/ClientMarquee.astro";
import IdcCtaBanner from "../components/IdcCtaBanner.astro";
---

<BaseLayout
  title="Fisto Tech Private Limited: Leading Interactive Digital Catalogue & Brochure Service Provider in India"
  description="Discover India’s leading digital catalog designers. Transform traditional PDFs into interactive catalogs that showcase your brand with style and impact."
  image="/images/about-og.jpg"
  current="idc"
  additionalStyles="/css/2d-3d-animation.css"
>
  <!-- ─────────── HERO SECTION ─────────── -->
  <section id="hero" class="section section--hero">
    <div class="hero">
      <!-- Left — Text -->
      <div class="hero__text">
        <h1
          class="hero__title"
          data-aos="trigger-anim"
          style="font-size: clamp(2rem, 3.5vw, 3rem);"
        >
          <span class="word-anim" style="animation-delay: 0.0s">Showcase,</span>
          <span class="word-anim" style="animation-delay: 0.05s">Share</span>
          <span class="word-anim" style="animation-delay: 0.1s">&amp;</span><br
          />
          <span class="word-anim" style="animation-delay: 0.15s">Sell</span>
          <span class="word-anim" style="animation-delay: 0.2s">Products</span>
          <span class="word-anim" style="animation-delay: 0.25s">with</span>
          <br />
          <span
            class="hero__highlight-events word-anim"
            style="animation-delay: 0.3s"
            >Interactive Digital <br /> Catalogues</span
          >
        </h1>
        <hr class="hero__divider" data-aos="fade-up" data-aos-delay="200" />
        <h2 class="hero__subtitle" data-aos="trigger-anim">
          <span class="word-anim" style="animation-delay: 0.4s">Want</span>
          <span class="word-anim" style="animation-delay: 0.45s">to</span>
          <span class="word-anim" style="animation-delay: 0.5s">Increase</span>
          <span class="word-anim" style="animation-delay: 0.55s">Your</span>
          <span class="word-anim" style="animation-delay: 0.6s">Sales</span>
          <br />
          <span class="word-anim" style="animation-delay: 0.65s">and</span>
          <span class="highlight-green word-anim" style="animation-delay: 0.7s"
            >Generate</span
          >
          <span class="highlight-green word-anim" style="animation-delay: 0.75s"
            >More</span
          >
          <span class="highlight-green word-anim" style="animation-delay: 0.8s"
            >Leads?</span
          >
        </h2>
        <div data-aos="trigger-anim">
          <p
            class="hero__description word-anim"
            style="animation-delay: 0.85s;"
          >
            We create <strong>Interactive Digital Catalogues</strong>, it help <strong
              >attract more visitors</strong
            >, <strong>engage customers</strong>, and <strong
              >generate quality leads</strong
            >.
          </p>
        </div>
        <div
          style="margin-top: 1.5rem; margin-bottom: 1rem;"
          data-aos="fade-up"
          data-aos-delay="500"
          class="hero-device-img-container"
        >
          <img
            src="/images/hero-section/hero-image-devices.webp"
            alt="Multiple Devices"
            style="width: 60%; max-width: 320px; height: auto;"
            loading="lazy"
          />
        </div>
      </div>
      <!-- Right — Visual -->
      <div
        class="hero__visual"
        data-aos="zoom-in-left"
        data-aos-delay="200"
        data-aos-duration="1200"
      >
        <video class="hero__video" autoplay muted loop playsinline>
          <source
            src="/images/services/IDC/hero-section-video.mp4"
            type="video/mp4"
          />
        </video>
      </div>
    </div>
  </section>
  <!-- ─────────── ABOUT US SECTION ─────────── -->
  <section id="about-us" class="section section--about">
    <div class="about-container">
      <div class="about__badge" data-aos="fade-down" data-aos-duration="800">
        WE ARE
      </div>
      <h2
        class="about__title"
        data-aos="flip-up"
        data-aos-delay="150"
        data-aos-duration="1000"
      >
        <span class="highlight">FISTO</span> TECH PVT LTD
      </h2>
      <div
        class="about__divider"
        data-aos="zoom-in"
        data-aos-delay="300"
        data-aos-duration="800"
      >
        <svg class="about__star" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
          ></path>
        </svg>
      </div>
      <p
        class="about__tagline"
        data-aos="fade-right"
        data-aos-delay="400"
        data-aos-duration="1000"
      >
        Creating Interactive <span class="highlight">Digital Experiences</span>
      </p>
      <p
        class="about__description"
        data-aos="fade-up"
        data-aos-delay="550"
        data-aos-duration="1000"
      >
        We transform ideas into engaging digital experiences through Interactive
        Digital Catalogues. Our focus on innovation and quality helps businesses
        connect with customers, generate leads, showcase products, and achieve
        measurable growth.
      </p>
    </div>
  </section>
  <!-- ─────────── IDC BANNER SECTION ─────────── -->
  <section id="first-time-banner" class="section section--first-time">
    <div class="first-time__container">
      <div
        class="first-time__left"
        data-aos="fade-up-right"
        data-aos-duration="1200"
      >
        <img
          src="/images/first-time/1st-text.webp"
          alt="1st"
          class="first-time__graphic"
        />
        <div class="first-time__content">
          <p class="first-time__badge">
            <!-- 1<sup class="first-time__sup">st</sup> -->
            TIME IN THE DIGITAL WORLD
          </p>
          <hr class="first-time__divider" />
          <h2 class="first-time__title">
            3D Interactive<br /><span class="first-time__highlight"
              >Digital Catalogue</span
            >
          </h2>
          <p class="first-time__desc">
            The Next Generation Interactive Digital Catalogue.<br />Impress your
            event visitors like never before.
          </p>
        </div>
      </div>
      <div
        class="first-time__right"
        data-aos="fade-down-left"
        data-aos-duration="1200"
        data-aos-delay="200"
      >
        <img
          src="/images/first-time/lap-image.webp"
          alt="Laptop Interactive Catalogue"
          class="first-time__laptop"
        />
      </div>
    </div>
  </section>
  <!-- ─────────── FEATURES SECTION (FOURTH) ─────────── -->
  <section id="features" class="section section--features">
    <div class="features-wrapper">
      <h2 class="features-header" data-aos="fade-down" data-aos-duration="800">
        FEATURES
      </h2>
      <div class="features-layout">
        <div
          class="features-diagram"
          data-aos="zoom-in-up"
          data-aos-duration="1200"
          data-aos-delay="200"
        >
          <img
            src="/images/features-image-new.webp"
            alt="Interactive Digital Catalogue Features"
            class="features-diagram__img"
            width="1024"
            height="722"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div
          class="features-footer"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="400"
        >
          <p>
            Smarter way. More Impact. One Powerful <span class="highlight"
              >Catalogue.</span>
          </p>
          <ul class="features-highlights" aria-label="Catalogue benefits">
            <li
              class="features-highlights__item"
              data-aos="fade-up"
              data-aos-delay="0"
            >
